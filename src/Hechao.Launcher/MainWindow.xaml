<Window x:Class="Hechao.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:contracts="clr-namespace:Hechao.Contracts;assembly=Hechao.Contracts"
        mc:Ignorable="d"
        Title="赫朝启动器"
        Width="1440"
        Height="900"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="{StaticResource UiFont}"
        Icon="/Assets/hechao-launcher.ico"
        Background="{StaticResource PaperBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="#FFCFC5BB" BorderThickness="1" Background="{StaticResource PaperBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Background="{StaticResource PaperRaisedBrush}"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0,0,0">
                    <Grid Width="44" Height="44">
                        <Border Background="{StaticResource InkBrush}" CornerRadius="4" Margin="1,3,3,1" />
                        <Border Background="{StaticResource HechaoRedBrush}" CornerRadius="4" Margin="0,0,4,4">
                            <TextBlock Text="C"
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       FontWeight="Black"
                                       FontSize="27"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <Rectangle Width="8" Height="8" Fill="{StaticResource PaperRaisedBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,3,1,0" />
                    </Grid>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="赫朝" FontSize="24" FontWeight="Black" />
                        <TextBlock Text="HECHAO" FontSize="9" FontWeight="Bold" Foreground="{StaticResource InkMutedBrush}" />
                    </StackPanel>
                    <Border Width="1" Height="28" Background="{StaticResource BorderBrush}" Margin="22,0" />
                    <TextBlock Text="服务器启动器" FontSize="13" Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource TitleBarButtonStyle}" Content="—" Click="MinimizeButton_OnClick" ToolTip="最小化" />
                    <Button Style="{StaticResource TitleBarButtonStyle}" Content="□" Click="MaximizeButton_OnClick" ToolTip="最大化或还原" />
                    <Button Style="{StaticResource CloseButtonStyle}" Content="×" Click="CloseButton_OnClick" ToolTip="关闭" />
                </StackPanel>

                <Border VerticalAlignment="Bottom" Height="1" Background="{StaticResource BorderBrush}" Grid.ColumnSpan="2" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#FFFFFBF6"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="78" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="132" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="24,0,20,0">
                            <TextBlock Text="服务器" FontSize="21" FontWeight="Black" VerticalAlignment="Center" />
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource IconButtonStyle}"
                                    Width="40"
                                    Height="40"
                                    FontSize="16"
                                    Content="&#xE72C;"
                                    Command="{Binding RefreshCommand}"
                                    ToolTip="刷新服务器状态" />
                        </Grid>

                        <ListBox Grid.Row="1"
                                 Margin="14,0,14,12"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemsSource="{Binding Servers}"
                                 SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource ServerListItemStyle}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type contracts:ServerSummary}">
                                    <Grid MinHeight="82">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="70" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="4" CornerRadius="0,3,3,0" Background="{StaticResource HechaoRedBrush}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Width="48"
                                                Height="48"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource PaperMutedBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                            <TextBlock Text="{Binding ShortName}"
                                                       FontSize="20"
                                                       FontWeight="Black"
                                                       Foreground="{StaticResource HechaoRedDarkBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="5,0,4,0">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" />
                                            <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                                                <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource ClosedBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static contracts:ServerStatus.Online}">
                                                                    <Setter Property="Fill" Value="{StaticResource OnlineBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                                    <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock FontSize="12" Foreground="{StaticResource InkMutedBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="未开放" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static contracts:ServerStatus.Online}">
                                                                    <Setter Property="Text" Value="在线" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                                    <Setter Property="Text" Value="维护中" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding OnlinePlayers}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" />
                                            <TextBlock FontSize="11" Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Right">
                                                <Run Text="/" />
                                                <Run Text="{Binding MaxPlayers}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Margin="20,0">
                            <Grid Margin="4,18,2,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="46" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="52"
                                        Height="52"
                                        Background="#FFD5A87A"
                                        BorderBrush="#FFB88456"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        VerticalAlignment="Center">
                                    <Canvas Width="44" Height="44" ClipToBounds="True">
                                        <Rectangle Canvas.Left="5" Canvas.Top="4" Width="34" Height="30" Fill="#FFB56E3E" />
                                        <Rectangle Canvas.Left="5" Canvas.Top="4" Width="34" Height="10" Fill="#FF3B2419" />
                                        <Rectangle Canvas.Left="5" Canvas.Top="11" Width="7" Height="11" Fill="#FF3B2419" />
                                        <Rectangle Canvas.Left="32" Canvas.Top="11" Width="7" Height="11" Fill="#FF3B2419" />
                                        <Rectangle Canvas.Left="12" Canvas.Top="18" Width="6" Height="5" Fill="#FFF8F2EA" />
                                        <Rectangle Canvas.Left="26" Canvas.Top="18" Width="6" Height="5" Fill="#FFF8F2EA" />
                                        <Rectangle Canvas.Left="14" Canvas.Top="19" Width="3" Height="3" Fill="#FF2C1A15" />
                                        <Rectangle Canvas.Left="27" Canvas.Top="19" Width="3" Height="3" Fill="#FF2C1A15" />
                                        <Rectangle Canvas.Left="10" Canvas.Top="34" Width="24" Height="10" Fill="#FF263C2D" />
                                    </Canvas>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6,0,0,0">
                                    <TextBlock Text="{Binding AccountDisplayName}"
                                               FontFamily="Segoe UI"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource ClosedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource OnlineBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding AccountStatusText}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding AccountAccessText}"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="42"
                                        Height="42"
                                        Content="{Binding AccountActionGlyph}"
                                        Command="{Binding AccountActionCommand}"
                                        ToolTip="{Binding AccountActionTooltip}"
                                        AutomationProperties.Name="{Binding AccountActionTooltip}"
                                        VerticalAlignment="Center" />

                                <Button Grid.Column="3"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="42"
                                        Height="42"
                                        Content="&#xE713;"
                                        Command="{Binding ToggleSettingsCommand}"
                                        ToolTip="启动器设置"
                                        AutomationProperties.Name="启动器设置"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="24,18,24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*" MinHeight="230" />
                        <RowDefinition Height="104" />
                        <RowDefinition Height="54" />
                        <RowDefinition Height="1.65*" MinHeight="176" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FFE9DFD5"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="/Assets/hechao-fortress-banner.png" Stretch="UniformToFill" />
                            <Border Width="106"
                                    Height="27"
                                    Background="#FFD4A34A"
                                    Opacity="0.72"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="22,-5,0,0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <RotateTransform Angle="-7" />
                                </Border.RenderTransform>
                            </Border>
                            <Border Width="98"
                                    Height="25"
                                    Background="{StaticResource HechaoRedBrush}"
                                    Opacity="0.76"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-4,20,0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <RotateTransform Angle="5" />
                                </Border.RenderTransform>
                            </Border>
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,18,16"
                                    Background="#CCFFF9F3"
                                    BorderBrush="{StaticResource HechaoRedBrush}"
                                    BorderThickness="2"
                                    Padding="8,5">
                                <TextBlock Text="赫朝" Foreground="{StaticResource HechaoRedDarkBrush}" FontSize="12" FontWeight="Black" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="10,0,6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedServer.Name}" FontSize="30" FontWeight="Black" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="{Binding SelectedServer.MinecraftVersion}" FontSize="13" Foreground="{StaticResource InkMutedBrush}" />
                                <TextBlock Text="  ·  " FontSize="13" Foreground="{StaticResource InkMutedBrush}" />
                                <TextBlock Text="{Binding SelectedServerLoaderText}" FontSize="13" Foreground="{StaticResource InkMutedBrush}" />
                                <TextBlock Text="  ·  " FontSize="13" Foreground="{StaticResource InkMutedBrush}" />
                                <Ellipse Width="8" Height="8" Fill="{StaticResource OnlineBrush}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedServerPlayerText}" FontSize="13" Foreground="{StaticResource InkMutedBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="&#xE7ED;"
                                Command="{Binding ToggleNotificationsCommand}"
                                ToolTip="通知"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNotificationsOpen}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource HechaoRedSoftBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource HechaoRedBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource HechaoRedDarkBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Grid.Column="2"
                                Content="&#xE713;"
                                Command="{Binding ToggleSettingsCommand}"
                                ToolTip="所选服务器设置"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource HechaoRedSoftBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource HechaoRedBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource HechaoRedDarkBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Grid.Column="3"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding PrimaryActionCommand}"
                                MinWidth="220"
                                Height="56"
                                Margin="18,0,0,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" Foreground="White" FontSize="17" Margin="0,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding PrimaryActionText}" Foreground="White" FontSize="17" FontWeight="Bold" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Grid.Row="2" Background="#FF1A1816" CornerRadius="4" Margin="0,1,0,6">
                        <Grid Margin="18,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE789;" FontFamily="{StaticResource IconFont}" Foreground="#FFDF4C40" FontSize="18" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="赫朝快讯" Foreground="White" FontSize="14" FontWeight="Bold" Margin="12,0,18,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="本周六 20:00 活动服开放" Foreground="#FFD9D4CE" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="＋" Foreground="{StaticResource HechaoRedBrush}" FontSize="19" FontWeight="Black" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Background="{StaticResource PaperRaisedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="20,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="客户端状态" FontSize="15" FontWeight="Bold" />

                            <Grid Grid.Row="1" Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="245" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="220" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <Border Background="{StaticResource HechaoRedSoftBrush}" BorderBrush="#FFE6CFC8" BorderThickness="1" CornerRadius="4" Padding="10,8" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE896;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource HechaoRedBrush}" FontSize="16" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding ClientStatusText}" Foreground="{StaticResource HechaoRedDarkBrush}" FontSize="13" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="0,13,0,0">
                                        <TextBlock Text="&#xE7B8;" FontFamily="{StaticResource IconFont}" FontSize="15" Margin="0,0,9,0" />
                                        <TextBlock Text="模组包 1.0.9" FontSize="13" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock Text="&#xE896;" FontFamily="{StaticResource IconFont}" FontSize="15" Margin="0,0,9,0" />
                                        <TextBlock Text="下载 126 MB" FontSize="13" />
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Column="1" Margin="14,0,24,0" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="更新进度" FontSize="12" Foreground="{StaticResource InkMutedBrush}" />
                                        <TextBlock Text="{Binding UpdateProgress, StringFormat={}{0:0}%}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right" />
                                    </Grid>
                                    <ProgressBar Grid.Row="1"
                                                 Style="{StaticResource HechaoProgressBarStyle}"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding UpdateProgress, Mode=OneWay}"
                                                 Margin="0,10,0,0" />
                                </Grid>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <Button Style="{StaticResource BaseButtonStyle}" Command="{Binding RepairCommand}" Height="42">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE90F;" FontFamily="{StaticResource IconFont}" FontSize="16" Margin="0,0,9,0" />
                                            <TextBlock Text="修复客户端" FontSize="13" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                    <Grid Margin="0,10,0,0" Height="40">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="116" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="30"
                                                Height="30"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource HechaoRedSoftBrush}"
                                                CornerRadius="4">
                                            <TextBlock Text="RAM"
                                                       FontFamily="Consolas"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource HechaoRedDarkBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="游戏内存" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Text="自动保存" FontSize="10" Foreground="{StaticResource InkMutedBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  Style="{StaticResource MemoryComboBoxStyle}"
                                                  ItemsSource="{Binding MemoryOptions}"
                                                  SelectedItem="{Binding SelectedMemory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="340"
                            Margin="0,72,12,0"
                            Padding="18"
                            Panel.ZIndex="20"
                            Background="{StaticResource PaperRaisedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Visibility="{Binding IsNotificationsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="通知" FontSize="17" FontWeight="Black" />
                                <Button HorizontalAlignment="Right" Style="{StaticResource BaseButtonStyle}" Padding="8,3" Content="关闭" Command="{Binding CloseOverlaysCommand}" />
                            </Grid>
                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,15">
                                <StackPanel>
                                    <TextBlock Text="活动服开放安排" FontSize="13" FontWeight="Bold" />
                                    <TextBlock Text="本周六 20:00 开放海绵小镇躲猫猫。" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <StackPanel Margin="0,14,0,0">
                                <TextBlock Text="客户端版本 1.0.9" FontSize="13" FontWeight="Bold" />
                                <TextBlock Text="已发布新的活动服客户端清单。" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,6,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.RowSpan="4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="420"
                            Margin="0,70,10,0"
                            Panel.ZIndex="20"
                            Background="{StaticResource PaperRaisedBrush}"
                            BorderBrush="#FFD7CCC2"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect Color="#44000000" BlurRadius="22" ShadowDepth="7" Direction="270" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{StaticResource HechaoRedBrush}" CornerRadius="6,6,0,0" />

                            <Grid Grid.Row="1" Margin="20,15,14,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid Width="38" Height="38" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border Background="{StaticResource InkBrush}" CornerRadius="4" Margin="1,2,2,0" />
                                    <Border Background="{StaticResource HechaoRedBrush}" CornerRadius="4" Margin="0,0,3,3">
                                        <TextBlock Text="C"
                                                   FontFamily="Consolas"
                                                   FontSize="23"
                                                   FontWeight="Black"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="7,0,0,0">
                                    <TextBlock Text="启动器设置" FontSize="18" FontWeight="Black" />
                                    <TextBlock Text="客户端与性能" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="34"
                                        Height="34"
                                        FontSize="13"
                                        Content="&#xE711;"
                                        Command="{Binding CloseOverlaysCommand}"
                                        ToolTip="关闭" />
                            </Grid>

                            <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                                <StackPanel Margin="20,15,20,14">
                                    <TextBlock Text="性能" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HechaoRedDarkBrush}" />
                                    <Grid Margin="0,8,0,0" Height="42">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="142" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="游戏内存" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="Minecraft" FontSize="10" Foreground="{StaticResource InkMutedBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  Style="{StaticResource MemoryComboBoxStyle}"
                                                  ItemsSource="{Binding MemoryOptions}"
                                                  SelectedItem="{Binding SelectedMemory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,14" />

                                    <TextBlock Text="存储" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HechaoRedDarkBrush}" />
                                    <Grid Margin="0,8,0,0" Height="42">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="38" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34" Height="34" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{StaticResource PaperMutedBrush}" CornerRadius="4">
                                            <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource IconFont}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="客户端目录" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ClientDirectory}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource InkMutedBrush}" Margin="0,2,8,0" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource IconButtonStyle}"
                                                Width="36"
                                                Height="36"
                                                FontSize="14"
                                                Content="&#xE8A7;"
                                                Command="{Binding OpenClientDirectoryCommand}"
                                                ToolTip="打开客户端目录" />
                                    </Grid>

                                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,14" />

                                    <TextBlock Text="启动行为" FontSize="11" FontWeight="Bold" Foreground="{StaticResource HechaoRedDarkBrush}" />
                                    <Grid Margin="0,8,0,0" Height="38">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="30" Height="30" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{StaticResource PaperMutedBrush}" CornerRadius="4">
                                            <TextBlock Text="&#xE895;" FontFamily="{StaticResource IconFont}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="启动时检查更新" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <ToggleButton Grid.Column="2"
                                                      Style="{StaticResource SwitchToggleStyle}"
                                                      IsChecked="{Binding CheckForUpdates, Mode=TwoWay}" />
                                    </Grid>
                                    <Grid Margin="0,5,0,0" Height="38">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="30" Height="30" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{StaticResource PaperMutedBrush}" CornerRadius="4">
                                            <TextBlock Text="&#xE896;" FontFamily="{StaticResource IconFont}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="关闭后保留下载任务" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <ToggleButton Grid.Column="2"
                                                      Style="{StaticResource SwitchToggleStyle}"
                                                      IsChecked="{Binding KeepDownloadsAfterClose, Mode=TwoWay}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="3" Background="{StaticResource PaperMutedBrush}" Padding="20,11" CornerRadius="0,0,6,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE73E;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource OnlineBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="设置自动保存" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="7,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding LauncherVersionText}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,9,0,0"
                                               Text="由赫朝独立运营。非 Minecraft 官方产品。未经 Mojang 或 Microsoft 批准，也不与 Mojang 或 Microsoft 关联。"
                                               TextWrapping="Wrap"
                                               FontSize="9"
                                               LineHeight="14"
                                               Foreground="{StaticResource InkMutedBrush}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,18"
                            Padding="18,10"
                            Panel.ZIndex="30"
                            Background="#F21A1816"
                            CornerRadius="4"
                            Visibility="{Binding IsToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="13" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
