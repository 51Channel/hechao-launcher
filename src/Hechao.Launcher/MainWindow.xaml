<Window x:Class="Hechao.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:contracts="clr-namespace:Hechao.Contracts;assembly=Hechao.Contracts"
        xmlns:controls="clr-namespace:Hechao.Launcher.Controls"
        mc:Ignorable="d"
        Title="赫朝启动器"
        Width="1500"
        Height="860"
        MinWidth="1060"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="{StaticResource UiFont}"
        Icon="/Assets/hechao-launcher.ico"
        Background="{StaticResource CanvasBrush}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource CanvasBrush}"
            BorderBrush="#FFC8C8C4"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavigationColumn" Width="84" />
                <ColumnDefinition x:Name="DirectoryColumn" Width="292" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Global navigation -->
            <Border Grid.Column="0"
                    Grid.RowSpan="2"
                    Background="{StaticResource RailBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="86" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="78" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <Border Width="40"
                                Height="40"
                                Background="{StaticResource HechaoRedBrush}"
                                CornerRadius="5">
                            <Image Source="/Assets/hechao-launcher-icon.png"
                                   Width="34"
                                   Height="34"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <TextBlock Text="赫朝"
                                   FontSize="13"
                                   FontWeight="Black"
                                   Margin="0,5,0,0"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="8,16,8,0">
                        <ToggleButton Style="{StaticResource RailNavigationToggleStyle}"
                                IsChecked="{Binding IsServersPage, Mode=OneWay}"
                                Command="{Binding ShowServersCommand}"
                                ToolTip="服务器大厅">
                            <StackPanel>
                                <controls:IconParkIcon Kind="Server"
                                                       Width="20"
                                                       Height="20"
                                                       HorizontalAlignment="Center" />
                                <TextBlock Text="服务器"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,5,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource RailNavigationToggleStyle}"
                                IsChecked="{Binding IsDownloadsPage, Mode=OneWay}"
                                Command="{Binding ShowDownloadsCommand}"
                                ToolTip="下载中心">
                            <StackPanel>
                                <controls:IconParkIcon Kind="Download"
                                                       Width="20"
                                                       Height="20"
                                                       HorizontalAlignment="Center" />
                                <TextBlock Text="下载"
                                           FontSize="12"
                                           Margin="0,5,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource RailNavigationToggleStyle}"
                                IsChecked="{Binding IsActivitiesPage, Mode=OneWay}"
                                Command="{Binding ShowActivitiesCommand}"
                                ToolTip="活动服目录">
                            <StackPanel>
                                <controls:IconParkIcon Kind="Calendar"
                                                       Width="20"
                                                       Height="20"
                                                       HorizontalAlignment="Center" />
                                <TextBlock Text="活动"
                                           FontSize="12"
                                           Margin="0,5,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource RailNavigationToggleStyle}"
                                IsChecked="{Binding IsAccountPage, Mode=OneWay}"
                                Command="{Binding ShowAccountCommand}"
                                ToolTip="{Binding AccountActionTooltip}">
                            <StackPanel>
                                <controls:IconParkIcon Kind="User"
                                                       Width="20"
                                                       Height="20"
                                                       HorizontalAlignment="Center" />
                                <TextBlock Text="账户"
                                           FontSize="12"
                                           Margin="0,5,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource RailNavigationToggleStyle}"
                                IsChecked="{Binding IsSettingsPage, Mode=OneWay}"
                                Command="{Binding ShowSettingsPageCommand}"
                                ToolTip="启动器设置">
                            <StackPanel>
                                <controls:IconParkIcon Kind="SettingTwo"
                                                       Width="20"
                                                       Height="20"
                                                       HorizontalAlignment="Center" />
                                <TextBlock Text="设置"
                                           FontSize="12"
                                           Margin="0,5,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>

                    <StackPanel Grid.Row="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LauncherVersionText}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="{StaticResource InkFaintBrush}"
                                   HorizontalAlignment="Center" />
                        <Ellipse Width="5"
                                 Height="5"
                                 Fill="{StaticResource OnlineBrush}"
                                 Margin="0,8,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Server directory -->
            <Border Grid.Column="1"
                    Grid.RowSpan="2"
                    Background="{StaticResource DirectoryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding IsServersPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="106" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="142" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20,0,16,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="服务器大厅"
                                       FontSize="20"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding Servers.Count, StringFormat={}{0} 个可选世界}"
                                       FontSize="12"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Width="38"
                                    Height="38"
                                    Content="&#xE72C;"
                                    Command="{Binding RefreshCommand}"
                                    ToolTip="刷新服务器状态"
                                    AutomationProperties.Name="刷新服务器状态" />
                        </StackPanel>
                        <Border Height="1"
                                Background="{StaticResource BorderBrush}"
                                VerticalAlignment="Bottom" />
                    </Grid>

                    <ListBox Grid.Row="1"
                             Margin="10,10,10,12"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemsSource="{Binding Servers}"
                             SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource ServerListItemStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type contracts:ServerSummary}">
                                <Grid Height="84">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="54" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="4"
                                            Background="{StaticResource HechaoRedBrush}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                 Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Width="44"
                                            Height="44"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="5">
                                        <TextBlock Text="{Binding ShortName}"
                                                   FontSize="17"
                                                   FontWeight="Black"
                                                   Foreground="{StaticResource HechaoRedDarkBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Margin="2,0,4,0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="Bold" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Ellipse Width="7"
                                                     Height="7"
                                                     Margin="0,0,6,0"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource ClosedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="{x:Static contracts:ServerStatus.Online}">
                                                                <Setter Property="Fill" Value="{StaticResource OnlineBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                                <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock FontSize="12" Foreground="{StaticResource InkMutedBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="未开放" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="{x:Static contracts:ServerStatus.Online}">
                                                                <Setter Property="Text" Value="在线" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                                <Setter Property="Text" Value="维护中" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding MinecraftVersion}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="11"
                                                   Foreground="{StaticResource InkFaintBrush}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,9,0">
                                        <TextBlock Text="{Binding OnlinePlayers}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock FontFamily="Segoe UI"
                                                   FontSize="11"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   HorizontalAlignment="Right">
                                            <Run Text="/" />
                                            <Run Text="{Binding MaxPlayers}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2"
                            Margin="16,0"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid Margin="0,18,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="54" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="46"
                                    Height="46"
                                    Background="#FFD1A071"
                                    BorderBrush="#FFB97B4A"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    VerticalAlignment="Center">
                                <Canvas Width="40" Height="40" ClipToBounds="True">
                                    <Rectangle Canvas.Left="4" Canvas.Top="3" Width="32" Height="27" Fill="#FFB56E3E" />
                                    <Rectangle Canvas.Left="4" Canvas.Top="3" Width="32" Height="9" Fill="#FF3B2419" />
                                    <Rectangle Canvas.Left="4" Canvas.Top="10" Width="6" Height="10" Fill="#FF3B2419" />
                                    <Rectangle Canvas.Left="30" Canvas.Top="10" Width="6" Height="10" Fill="#FF3B2419" />
                                    <Rectangle Canvas.Left="10" Canvas.Top="16" Width="6" Height="5" Fill="#FFF8F2EA" />
                                    <Rectangle Canvas.Left="24" Canvas.Top="16" Width="6" Height="5" Fill="#FFF8F2EA" />
                                    <Rectangle Canvas.Left="12" Canvas.Top="17" Width="3" Height="3" Fill="#FF2C1A15" />
                                    <Rectangle Canvas.Left="25" Canvas.Top="17" Width="3" Height="3" Fill="#FF2C1A15" />
                                    <Rectangle Canvas.Left="8" Canvas.Top="30" Width="24" Height="10" Fill="#FF263C2D" />
                                </Canvas>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="5,0,5,0">
                                <TextBlock Text="{Binding AccountDisplayName}"
                                           FontFamily="Segoe UI"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource ClosedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource OnlineBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding AccountStatusText}"
                                               FontSize="12"
                                               Foreground="{StaticResource InkMutedBrush}" />
                                </StackPanel>
                                <TextBlock Text="{Binding AccountAccessText}"
                                           FontSize="11"
                                           Foreground="{StaticResource InkFaintBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Style="{StaticResource QuietIconButtonStyle}"
                                    Width="38"
                                    Height="38"
                                    Content="{Binding AccountActionGlyph}"
                                    Command="{Binding AccountActionCommand}"
                                    ToolTip="{Binding AccountActionTooltip}"
                                    AutomationProperties.Name="{Binding AccountActionTooltip}"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Main title bar -->
            <Grid x:Name="TitleBar"
                  Grid.Column="2"
                  Grid.Row="0"
                  Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown"
                  Visibility="{Binding IsServersPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="28,0,0,0">
                    <TextBlock Text="服务器"
                               FontSize="14"
                               Foreground="{StaticResource InkMutedBrush}"
                               VerticalAlignment="Center" />
                    <controls:IconParkIcon Kind="Right"
                                           Width="10"
                                           Height="10"
                                           Foreground="{StaticResource InkFaintBrush}"
                                           Margin="11,0"
                                           VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SelectedServer.Name}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Grid Width="46" Height="64">
                        <Button Style="{StaticResource QuietIconButtonStyle}"
                                Width="38"
                                Height="38"
                                Content="&#xE7F4;"
                                Command="{Binding ToggleNotificationsCommand}"
                                ToolTip="通知"
                                AutomationProperties.Name="通知"
                                VerticalAlignment="Center" />
                        <Ellipse Width="6"
                                 Height="6"
                                 Fill="{StaticResource HechaoRedBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,17,7,0"
                                 IsHitTestVisible="False" />
                    </Grid>
                    <Button Style="{StaticResource QuietIconButtonStyle}"
                            Width="46"
                            Height="64"
                            Content="&#xE713;"
                            Command="{Binding ShowSettingsPageCommand}"
                            ToolTip="启动器设置"
                            AutomationProperties.Name="启动器设置" />
                    <Border Width="1"
                            Height="24"
                            Background="{StaticResource BorderBrush}"
                            Margin="4,0,6,0"
                            VerticalAlignment="Center" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Height="64"
                            Content="&#xE921;"
                            Click="MinimizeButton_OnClick"
                            ToolTip="最小化" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Height="64"
                            Content="&#xE922;"
                            Click="MaximizeButton_OnClick"
                            ToolTip="最大化或还原" />
                    <Button Style="{StaticResource CloseButtonStyle}"
                            Height="64"
                            Content="&#xE8BB;"
                            Click="CloseButton_OnClick"
                            ToolTip="关闭" />
                </StackPanel>

                <Border Grid.ColumnSpan="2"
                        Height="1"
                        Background="{StaticResource BorderBrush}"
                        VerticalAlignment="Bottom" />
            </Grid>

            <!-- Server workspace -->
            <Grid Grid.Column="2"
                  Grid.Row="1"
                  Background="{StaticResource SurfaceBrush}"
                  Visibility="{Binding IsServersPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" MinHeight="170" MaxHeight="270" />
                    <RowDefinition Height="128" />
                    <RowDefinition Height="44" />
                    <RowDefinition Height="3*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ClipToBounds="True">
                    <Image Source="/Assets/hechao-fortress-banner.png"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="22,16,0,0">
                        <Border Padding="12,7"
                                Background="#F5FFFFFF"
                                BorderBrush="#30FFFFFF"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource ClosedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}"
                                                             Value="{x:Static contracts:ServerStatus.Online}">
                                                    <Setter Property="Fill" Value="{StaticResource OnlineBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedServer.Status}"
                                                             Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                    <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding SelectedServerStatusText}"
                                           FontSize="13"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Padding="12,7"
                                Margin="7,0,0,0"
                                Background="#F5FFFFFF"
                                BorderBrush="#30FFFFFF"
                                BorderThickness="1"
                                CornerRadius="4">
                            <TextBlock Text="{Binding SelectedServerCategoryText}"
                                       FontSize="13"
                                       Foreground="{StaticResource HechaoRedDarkBrush}"
                                       FontWeight="Bold" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="28,0,26,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedServer.Name}"
                                       FontSize="28"
                                       FontWeight="Black" />
                            <TextBlock Text="{Binding SelectedServerDescriptionText}"
                                       FontSize="13"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       Margin="0,6,0,0" />
                            <WrapPanel Margin="0,12,0,0">
                                <controls:IconParkIcon Kind="Box"
                                                       Width="12"
                                                       Height="12"
                                                       Foreground="{StaticResource SteelBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0" />
                                <TextBlock Text="{Binding SelectedServerVersionText}"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           VerticalAlignment="Center" />
                                <Border Width="1" Height="12" Background="{StaticResource BorderBrush}" Margin="13,0" />
                                <controls:IconParkIcon Kind="User"
                                                       Width="12"
                                                       Height="12"
                                                       Foreground="{StaticResource SteelBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0" />
                                <TextBlock Text="{Binding SelectedServerAccessText}"
                                           FontSize="12"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           VerticalAlignment="Center" />
                                <Border Width="1" Height="12" Background="{StaticResource BorderBrush}" Margin="13,0" />
                                <Ellipse Width="7"
                                         Height="7"
                                         Fill="{StaticResource OnlineBrush}"
                                         Margin="0,0,6,0"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedServerPlayerText}"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           VerticalAlignment="Center" />
                            </WrapPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="206"
                                Height="56"
                                Margin="28,0,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding PrimaryActionCommand}"
                                AutomationProperties.Name="{Binding PrimaryActionText}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <controls:IconParkIcon Glyph="{Binding PrimaryActionGlyph}"
                                                       Width="16"
                                                       Height="16"
                                                       Foreground="White"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding PrimaryActionText}"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource StripBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="28,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <controls:IconParkIcon Kind="VolumeNotice"
                                               Width="14"
                                               Height="14"
                                               Foreground="{StaticResource HechaoRedBrush}"
                                               VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="赫朝快讯"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,14,0" />
                        <Border Grid.Column="2"
                                Height="16"
                                Background="{StaticResource BorderBrush}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3"
                                   Text="活动服务器会按录制计划开放，客户端将自动匹配当前版本。"
                                   FontSize="12"
                                   Foreground="{StaticResource InkMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="14,0" />
                        <Button Grid.Column="4"
                                Style="{StaticResource QuietIconButtonStyle}"
                                Width="36"
                                Height="36"
                                Content="&#xE8A7;"
                                Command="{Binding ToggleNotificationsCommand}"
                                ToolTip="查看全部通知" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="3"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <Grid MinHeight="292">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56*" />
                        <ColumnDefinition Width="44*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="42" />
                    </Grid.RowDefinitions>

                    <!-- Client readiness -->
                    <Grid Grid.Column="0" Margin="28,20,26,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="42" />
                            <RowDefinition Height="66" />
                            <RowDefinition Height="72" />
                            <RowDefinition Height="66" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                <Border Width="30"
                                        Height="30"
                                        Background="{StaticResource HechaoRedSoftBrush}"
                                        CornerRadius="4">
                                    <controls:IconParkIcon Kind="Box"
                                                           Width="13"
                                                           Height="13"
                                                           Foreground="{StaticResource HechaoRedDarkBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="10,-1,0,0">
                                    <TextBlock Text="客户端准备"
                                               FontSize="17"
                                               FontWeight="Black" />
                                    <TextBlock Text="{Binding ClientStatusText}"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{Binding LauncherVersionText, StringFormat=启动器 {0}}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       Foreground="{StaticResource InkFaintBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Margin="0,5,0,0" />
                        </Grid>

                        <Grid Grid.Row="1"
                              Margin="5,4,5,0"
                              VerticalAlignment="Top">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="31" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="1"
                                    Grid.ColumnSpan="4"
                                    Height="1"
                                    Margin="28,0"
                                    Background="{StaticResource BorderBrush}"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="0"
                                       Text="检查环境"
                                       Style="{StaticResource ProcessLabelStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text="获取清单"
                                       Style="{StaticResource ProcessLabelStyle}" />
                            <TextBlock Grid.Column="2"
                                       Text="下载资源"
                                       Style="{StaticResource ProcessLabelStyle}" />
                            <TextBlock Grid.Column="3"
                                       Text="校验文件"
                                       Style="{StaticResource ProcessLabelStyle}" />
                            <Ellipse Grid.Row="1"
                                     Grid.Column="0"
                                     Width="17"
                                     Height="17"
                                     Fill="{StaticResource SurfaceBrush}"
                                     Stroke="{StaticResource SteelBrush}"
                                     StrokeThickness="2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Ellipse Grid.Row="1"
                                     Grid.Column="1"
                                     Width="17"
                                     Height="17"
                                     Fill="{StaticResource SurfaceBrush}"
                                     Stroke="{StaticResource BorderStrongBrush}"
                                     StrokeThickness="2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Ellipse Grid.Row="1"
                                     Grid.Column="2"
                                     Width="17"
                                     Height="17"
                                     Fill="{StaticResource SurfaceBrush}"
                                     Stroke="{StaticResource BorderStrongBrush}"
                                     StrokeThickness="2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Ellipse Grid.Row="1"
                                     Grid.Column="3"
                                     Width="17"
                                     Height="17"
                                     Fill="{StaticResource SurfaceBrush}"
                                     Stroke="{StaticResource BorderStrongBrush}"
                                     StrokeThickness="2"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="客户端包"
                                           FontSize="11"
                                           Foreground="{StaticResource InkMutedBrush}" />
                                <TextBlock Text="{Binding SelectedProfileDisplayName}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Margin="0,5,0,0" />
                                <TextBlock Text="{Binding SelectedProfileMetaText}"
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           Foreground="{StaticResource InkFaintBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Grid Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <TextBlock Text="进度"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}" />
                                    <TextBlock Text="{Binding UpdateProgress, StringFormat={}{0:0}%}"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Right" />
                                </Grid>
                                <ProgressBar Grid.Row="1"
                                             Style="{StaticResource HechaoProgressBarStyle}"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding UpdateProgress, Mode=OneWay}"
                                             Margin="0,9,0,0" />
                                <TextBlock Grid.Row="2"
                                           Text="{Binding ClientStatusText}"
                                           FontSize="11"
                                           Foreground="{StaticResource InkFaintBrush}"
                                           Margin="0,6,0,0" />
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="18" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="安装路径"
                                       FontSize="11"
                                       Foreground="{StaticResource InkMutedBrush}" />
                            <Border Grid.Row="1"
                                    Background="{StaticResource SurfaceMutedBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid Margin="12,0,4,0">
                                    <TextBlock Text="{Binding ClientDirectory}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               VerticalAlignment="Center" />
                                    <Button HorizontalAlignment="Right"
                                            Style="{StaticResource QuietIconButtonStyle}"
                                            Width="34"
                                            Height="34"
                                            Content="&#xE838;"
                                            Command="{Binding OpenClientDirectoryCommand}"
                                            ToolTip="打开客户端目录" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Runtime configuration -->
                    <Border Grid.Column="1"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1,0,0,0">
                        <Grid Margin="28,20,28,18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="42" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="82" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="30"
                                            Height="30"
                                            Background="{StaticResource SteelSoftBrush}"
                                            CornerRadius="4">
                                        <controls:IconParkIcon Kind="SettingTwo"
                                                               Width="13"
                                                               Height="13"
                                                               Foreground="{StaticResource SteelBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Margin="10,-1,0,0">
                                        <TextBlock Text="运行配置"
                                                   FontSize="17"
                                                   FontWeight="Black" />
                                        <TextBlock Text="保存后在下次启动时生效"
                                                   FontSize="11"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Style="{StaticResource DetailRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <controls:IconParkIcon Kind="Box" Style="{StaticResource DetailRowIconStyle}" />
                                <TextBlock Text="运行环境" Style="{StaticResource DetailRowLabelStyle}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectedServerLoaderText}"
                                           Style="{StaticResource DetailRowValueStyle}" />
                            </Grid>
                            <Grid Grid.Row="2" Style="{StaticResource DetailRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <controls:IconParkIcon Kind="Code" Style="{StaticResource DetailRowIconStyle}" />
                                <TextBlock Text="Java 版本" Style="{StaticResource DetailRowLabelStyle}" />
                                <TextBlock Grid.Column="1"
                                           Text="Java 21"
                                           Style="{StaticResource DetailRowValueStyle}" />
                            </Grid>
                            <Grid Grid.Row="3" Style="{StaticResource DetailRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <controls:IconParkIcon Kind="Folder" Style="{StaticResource DetailRowIconStyle}" />
                                <TextBlock Text="游戏目录" Style="{StaticResource DetailRowLabelStyle}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ClientDirectory}"
                                           FontFamily="Consolas"
                                           Style="{StaticResource DetailRowValueStyle}" />
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="44" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="内存分配"
                                           FontSize="11"
                                           Foreground="{StaticResource InkMutedBrush}" />
                                <ListBox Grid.Row="1"
                                         Style="{StaticResource MemorySegmentListStyle}"
                                         ItemContainerStyle="{StaticResource MemorySegmentItemStyle}"
                                         ItemsSource="{Binding MemoryOptions}"
                                         SelectedItem="{Binding SelectedMemory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Grid Grid.Row="5" Margin="0,18,0,0" VerticalAlignment="Bottom">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Style="{StaticResource BaseButtonStyle}"
                                        Height="42"
                                        Margin="0,0,5,0"
                                        Command="{Binding RepairCommand}"
                                        ToolTip="校验并修复当前客户端">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconParkIcon Kind="Repair"
                                                               Width="14"
                                                               Height="14"
                                                               Margin="0,0,8,0" />
                                        <TextBlock Text="修复客户端"
                                                   FontSize="13"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1"
                                        Style="{StaticResource BaseButtonStyle}"
                                        Height="42"
                                        Margin="5,0,0,0"
                                        Command="{Binding ShowSettingsPageCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconParkIcon Kind="SettingTwo"
                                                               Width="14"
                                                               Height="14"
                                                               Margin="0,0,8,0" />
                                        <TextBlock Text="更多设置"
                                                   FontSize="13"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Background="{StaticResource StripBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid Margin="28,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="活动记录"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ClientStatusText}"
                                       FontSize="11"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       VerticalAlignment="Center"
                                       Margin="24,0,0,0" />
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Ellipse Width="6"
                                         Height="6"
                                         Fill="{StaticResource OnlineBrush}"
                                         Margin="0,0,7,0" />
                                <TextBlock Text="设置自动保存"
                                           FontSize="11"
                                           Foreground="{StaticResource InkMutedBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Shared title bar for non-server pages -->
            <Grid Grid.Column="1"
                  Grid.ColumnSpan="2"
                  Grid.Row="0"
                  Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown"
                  Panel.ZIndex="5">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsServersPage}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                            Margin="26,0,0,0"
                            VerticalAlignment="Center">
                    <Border Width="28"
                            Height="28"
                            Background="{StaticResource HechaoRedBrush}"
                            CornerRadius="4">
                        <Image Source="/Assets/hechao-launcher-icon.png"
                               Width="24"
                               Height="24"
                               Stretch="Uniform" />
                    </Border>
                    <TextBlock Text="赫朝"
                               FontSize="14"
                               FontWeight="Black"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center" />
                    <controls:IconParkIcon Kind="Right"
                                           Width="10"
                                           Height="10"
                                           Foreground="{StaticResource InkFaintBrush}"
                                           Margin="12,0"
                                           VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrentPageTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource QuietIconButtonStyle}"
                            Width="46"
                            Height="64"
                            Content="&#xE7F4;"
                            Command="{Binding ToggleNotificationsCommand}"
                            ToolTip="通知" />
                    <Border Width="1"
                            Height="24"
                            Background="{StaticResource BorderBrush}"
                            Margin="4,0,6,0"
                            VerticalAlignment="Center" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Height="64"
                            Content="&#xE921;"
                            Click="MinimizeButton_OnClick"
                            ToolTip="最小化" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Height="64"
                            Content="&#xE922;"
                            Click="MaximizeButton_OnClick"
                            ToolTip="最大化或还原" />
                    <Button Style="{StaticResource CloseButtonStyle}"
                            Height="64"
                            Content="&#xE8BB;"
                            Click="CloseButton_OnClick"
                            ToolTip="关闭" />
                </StackPanel>
                <Border Grid.ColumnSpan="2"
                        Height="1"
                        Background="{StaticResource BorderBrush}"
                        VerticalAlignment="Bottom" />
            </Grid>

            <!-- Downloads page -->
            <Grid Grid.Column="1"
                  Grid.ColumnSpan="2"
                  Grid.Row="1"
                  Background="{StaticResource CanvasBrush}"
                  Visibility="{Binding IsDownloadsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="34,28,34,34" MaxWidth="1260">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="CONTENT DELIVERY"
                                           Style="{StaticResource PageEyebrowStyle}" />
                                <TextBlock Text="下载中心"
                                           Style="{StaticResource PageHeaderTitleStyle}"
                                           Margin="0,5,0,0" />
                                <TextBlock Text="{Binding DownloadQueueStatusText}"
                                           FontSize="13"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           Margin="0,7,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <Button Style="{StaticResource BaseButtonStyle}"
                                        Command="{Binding OpenClientDirectoryCommand}"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconParkIcon Kind="FolderOpen"
                                                               Width="14"
                                                               Height="14"
                                                               Margin="0,0,8,0" />
                                        <TextBlock Text="打开客户端目录" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource BaseButtonStyle}"
                                        Command="{Binding ClearDownloadHistoryCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconParkIcon Kind="Delete"
                                                               Width="14"
                                                               Height="14"
                                                               Margin="0,0,8,0" />
                                        <TextBlock Text="清空历史" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Style="{StaticResource SurfacePanelStyle}"
                                Margin="0,26,0,0"
                                Padding="24">
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasActiveDownload}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="36"
                                        Height="36"
                                        Background="{StaticResource HechaoRedSoftBrush}"
                                        CornerRadius="4"
                                        VerticalAlignment="Top">
                                    <controls:IconParkIcon Kind="Download"
                                                           Width="16"
                                                           Height="16"
                                                           Foreground="{StaticResource HechaoRedDarkBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                </Border>
                                <Grid Grid.Column="1" Margin="10,0,24,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <TextBlock Text="{Binding ActiveDownload.DisplayName}"
                                                   FontSize="17"
                                                   FontWeight="Black" />
                                        <TextBlock Text="{Binding ActiveDownload.ProgressText}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding ActiveDownload.CurrentFile}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,7,0,0" />
                                    <ProgressBar Grid.Row="2"
                                                 Style="{StaticResource HechaoProgressBarStyle}"
                                                 Value="{Binding ActiveDownload.Percent}"
                                                 Maximum="100"
                                                 Margin="0,12,0,0" />
                                    <TextBlock Grid.Row="3"
                                               Text="{Binding ActiveDownload.Version, StringFormat=客户端版本 {0}}"
                                               FontFamily="Segoe UI"
                                               FontSize="11"
                                               Foreground="{StaticResource InkFaintBrush}"
                                               Margin="0,8,0,0" />
                                </Grid>
                                <Button Grid.Column="2"
                                        Style="{StaticResource BaseButtonStyle}"
                                        Command="{Binding CancelDownloadCommand}"
                                        VerticalAlignment="Center"
                                        Content="取消任务" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,26,0,0"
                                Padding="24"
                                Background="{StaticResource SurfaceMutedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNoActiveDownload}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <controls:IconParkIcon Kind="Download"
                                                       Width="20"
                                                       Height="20"
                                                       Foreground="{StaticResource InkFaintBrush}"
                                                       VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="当前没有正在进行的任务"
                                               FontSize="15"
                                               FontWeight="Bold" />
                                    <TextBlock Text="从服务器页安装或修复客户端后，实时速度、文件和校验进度会显示在这里。"
                                               FontSize="12"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2" Margin="0,28,0,12">
                            <TextBlock Text="下载历史"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="{Binding DownloadHistoryCount, StringFormat={}{0} 条记录}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="3">
                            <ListBox ItemsSource="{Binding DownloadHistory}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ItemContainerStyle="{StaticResource PageListItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource SurfacePanelStyle}"
                                                Padding="20,16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="38" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="110" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="30"
                                                        Height="30"
                                                        Background="{StaticResource SteelSoftBrush}"
                                                        CornerRadius="4">
                                                    <controls:IconParkIcon Kind="Download"
                                                                           Width="13"
                                                                           Height="13"
                                                                           Foreground="{StaticResource SteelBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="8,0,20,0">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="14"
                                                               FontWeight="Bold" />
                                                    <TextBlock Text="{Binding FailureMessage}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource InkMutedBrush}"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ProgressText}"
                                                               FontFamily="Segoe UI"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Version, StringFormat=版本 {0}}"
                                                               FontFamily="Segoe UI"
                                                               FontSize="11"
                                                               Foreground="{StaticResource InkFaintBrush}"
                                                               Margin="0,3,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="3"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource HechaoRedDarkBrush}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding TimeText}"
                                                               FontFamily="Segoe UI"
                                                               FontSize="11"
                                                               Foreground="{StaticResource InkFaintBrush}"
                                                               Margin="0,3,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Padding="26"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasNoDownloadHistory}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="完成过的安装、更新、修复和中断任务都会保存在这里。"
                                           FontSize="13"
                                           Foreground="{StaticResource InkMutedBrush}" />
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Activities page -->
            <Grid Grid.Column="1"
                  Grid.ColumnSpan="2"
                  Grid.Row="1"
                  Background="{StaticResource CanvasBrush}"
                  Visibility="{Binding IsActivitiesPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="34,28,34,34" MaxWidth="1260">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="LIMITED OPERATIONS"
                                           Style="{StaticResource PageEyebrowStyle}" />
                                <TextBlock Text="活动服目录"
                                           Style="{StaticResource PageHeaderTitleStyle}"
                                           Margin="0,5,0,0" />
                                <TextBlock Text="每场活动都使用独立客户端档案，启动器会自动准备对应模组与资源。"
                                           FontSize="13"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           TextWrapping="Wrap"
                                           TextTrimming="None"
                                           Margin="0,7,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource BaseButtonStyle}"
                                    Command="{Binding RefreshCommand}"
                                    VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconParkIcon Kind="Refresh"
                                                           Width="14"
                                                           Height="14"
                                                           Margin="0,0,8,0" />
                                    <TextBlock Text="刷新状态" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,24,0,20"
                                Background="{StaticResource StripBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1,0"
                                Padding="18,12">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconParkIcon Kind="VolumeNotice"
                                                           Width="14"
                                                           Height="14"
                                                           Foreground="{StaticResource HechaoRedBrush}"
                                                           Margin="0,0,10,0" />
                                    <TextBlock Text="活动录制以公告时间为准，未开放的活动仍可提前安装客户端。"
                                               FontSize="12"
                                               Foreground="{StaticResource InkMutedBrush}" />
                                </StackPanel>
                                <TextBlock Text="{Binding ActivityServerCount, StringFormat={}{0} 个活动档案}"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <ListBox ItemsSource="{Binding ActivityServers}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ItemContainerStyle="{StaticResource PageListItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type contracts:ServerSummary}">
                                        <Border Width="370"
                                                MinHeight="218"
                                                Margin="0,0,10,2"
                                                Padding="20"
                                                Style="{StaticResource SurfacePanelStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="52" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="42"
                                                            Height="42"
                                                            Background="{StaticResource HechaoRedSoftBrush}"
                                                            CornerRadius="4">
                                                        <TextBlock Text="{Binding IconGlyph}"
                                                                   FontSize="18"
                                                                   FontWeight="Black"
                                                                   Foreground="{StaticResource HechaoRedDarkBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="16"
                                                                   FontWeight="Black" />
                                                        <TextBlock Text="{Binding ShortName}"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource InkMutedBrush}"
                                                                   Margin="0,4,0,0" />
                                                    </StackPanel>
                                                    <Border Grid.Column="2"
                                                            Padding="9,5"
                                                            Background="{StaticResource SurfaceMutedBrush}"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            VerticalAlignment="Top">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="7"
                                                                     Height="7"
                                                                     Margin="0,0,6,0"
                                                                     VerticalAlignment="Center">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Fill" Value="{StaticResource ClosedBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}"
                                                                                         Value="{x:Static contracts:ServerStatus.Online}">
                                                                                <Setter Property="Fill" Value="{StaticResource OnlineBrush}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}"
                                                                                         Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                                                <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                            <TextBlock FontSize="11" FontWeight="Bold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="未开放" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Status}"
                                                                                         Value="{x:Static contracts:ServerStatus.Online}">
                                                                                <Setter Property="Text" Value="在线" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Status}"
                                                                                         Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                                                <Setter Property="Text" Value="维护中" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <Grid Grid.Row="1" Margin="0,22,0,16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="版本" FontSize="11" Foreground="{StaticResource InkFaintBrush}" />
                                                        <TextBlock Text="{Binding MinecraftVersion}"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   Margin="0,5,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="加载器" FontSize="11" Foreground="{StaticResource InkFaintBrush}" />
                                                        <TextBlock Text="{Binding Loader}"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   Margin="0,5,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="在线" FontSize="11" Foreground="{StaticResource InkFaintBrush}" />
                                                        <TextBlock FontFamily="Segoe UI"
                                                                   FontSize="13"
                                                                   FontWeight="Bold"
                                                                   Margin="0,5,0,0">
                                                            <Run Text="{Binding OnlinePlayers}" />
                                                            <Run Text="/" />
                                                            <Run Text="{Binding MaxPlayers}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <Button Grid.Row="2"
                                                        Height="42"
                                                        Style="{StaticResource BaseButtonStyle}"
                                                        Command="{Binding DataContext.ViewActivityServerCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <controls:IconParkIcon Kind="Right"
                                                                               Width="14"
                                                                               Height="14"
                                                                               Margin="0,0,8,0" />
                                                        <TextBlock Text="查看客户端与进入条件" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border Padding="28">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource SurfacePanelStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasActivityServers}" Value="False">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="当前目录中还没有活动服务器。"
                                           FontSize="14"
                                           Foreground="{StaticResource InkMutedBrush}" />
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Hechao account page -->
            <Grid Grid.Column="1"
                  Grid.ColumnSpan="2"
                  Grid.Row="1"
                  Background="{StaticResource CanvasBrush}"
                  Visibility="{Binding IsAccountPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="34,28,34,34" MaxWidth="1180">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="IDENTITY &amp; ACCESS"
                                       Style="{StaticResource PageEyebrowStyle}" />
                            <TextBlock Text="赫朝账户"
                                       Style="{StaticResource PageHeaderTitleStyle}"
                                       Margin="0,5,0,0" />
                            <TextBlock Text="赫朝账号负责社区身份与权限，Microsoft 正版身份只用于验证 Minecraft Java 版所有权。"
                                       FontSize="13"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       TextWrapping="Wrap"
                                       TextTrimming="None"
                                       Margin="0,7,0,0" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,26,0,0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44*" />
                                <ColumnDefinition Width="56*" />
                            </Grid.ColumnDefinitions>

                            <Border Margin="0,0,12,0"
                                    Style="{StaticResource SurfacePanelStyle}"
                                    Padding="26">
                                <StackPanel>
                                    <TextBlock Text="登录顺序"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="先建立赫朝身份，再绑定正版游戏身份。两者职责分开，改绑和权限同步更清楚。"
                                               FontSize="12"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Margin="0,8,0,24" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                Background="{StaticResource HechaoRedBrush}"
                                                CornerRadius="4"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="1"
                                                       FontFamily="Segoe UI"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="赫朝账号"
                                                       FontSize="15"
                                                       FontWeight="Black" />
                                            <TextBlock Text="社区昵称、等级、活动资格和管理权限都归属于这个账号。"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None"
                                                       Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <Border Width="1"
                                            Height="34"
                                            Margin="16,6,0,6"
                                            Background="{StaticResource BorderStrongBrush}"
                                            HorizontalAlignment="Left" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                Background="{StaticResource SteelSoftBrush}"
                                                BorderBrush="{StaticResource BorderStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="2"
                                                       FontFamily="Segoe UI"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource SteelBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Microsoft / Minecraft"
                                                       FontSize="15"
                                                       FontWeight="Black" />
                                            <TextBlock Text="验证账号拥有 Minecraft Java 版。完成后才可由启动器进入服务器。"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None"
                                                       Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Margin="0,28,0,0"
                                            Padding="16"
                                            Background="{StaticResource SurfaceMutedBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <StackPanel Orientation="Horizontal">
                                            <controls:IconParkIcon Kind="ExternalTransmission"
                                                                   Width="16"
                                                                   Height="16"
                                                                   Foreground="{StaticResource SteelBrush}"
                                                                   Margin="0,0,12,0" />
                                            <TextBlock Text="启动器不会要求你在赫朝账号中填写 Microsoft 密码。"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource SurfacePanelStyle}"
                                    Padding="26">
                                <StackPanel>
                                <TabControl Background="Transparent"
                                            BorderThickness="0">
                                    <TabControl.Resources>
                                        <Style TargetType="TabItem"
                                               BasedOn="{StaticResource AccountTabStyle}" />
                                    </TabControl.Resources>
                                    <TabItem Header="登录">
                                        <Grid Margin="0,24,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="账号名或邮箱"
                                                       Style="{StaticResource FormLabelStyle}" />
                                            <TextBox x:Name="LoginIdentifierTextBox"
                                                     Grid.Row="1"
                                                     Style="{StaticResource TextFieldStyle}"
                                                     AutomationProperties.Name="赫朝账号名或邮箱" />
                                            <TextBlock Grid.Row="2"
                                                       Text="密码"
                                                       Style="{StaticResource FormLabelStyle}"
                                                       Margin="0,16,0,6" />
                                            <PasswordBox x:Name="LoginPasswordBox"
                                                         Grid.Row="3"
                                                         Style="{StaticResource PasswordFieldStyle}"
                                                         AutomationProperties.Name="赫朝账号密码" />
                                            <Button Grid.Row="4"
                                                    Height="46"
                                                    Margin="0,22,0,0"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="LoginAccountButton_OnClick">
                                                <TextBlock Text="登录赫朝账号"
                                                           Foreground="White"
                                                           FontSize="14"
                                                           FontWeight="Bold" />
                                            </Button>
                                        </Grid>
                                    </TabItem>
                                    <TabItem Header="注册">
                                        <Grid Margin="0,24,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="账号名"
                                                       Style="{StaticResource FormLabelStyle}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="显示名称"
                                                       Style="{StaticResource FormLabelStyle}"
                                                       Margin="10,0,0,6" />
                                            <TextBox x:Name="RegisterUsernameTextBox"
                                                     Grid.Row="1"
                                                     Margin="0,0,10,0"
                                                     Style="{StaticResource TextFieldStyle}"
                                                     AutomationProperties.Name="赫朝账号名" />
                                            <TextBox x:Name="RegisterDisplayNameTextBox"
                                                     Grid.Row="1"
                                                     Grid.Column="1"
                                                     Margin="10,0,0,0"
                                                     Style="{StaticResource TextFieldStyle}"
                                                     AutomationProperties.Name="显示名称" />
                                            <TextBlock Grid.Row="2"
                                                       Grid.ColumnSpan="2"
                                                       Text="邮箱（可选）"
                                                       Style="{StaticResource FormLabelStyle}"
                                                       Margin="0,16,0,6" />
                                            <TextBox x:Name="RegisterEmailTextBox"
                                                     Grid.Row="3"
                                                     Grid.ColumnSpan="2"
                                                     Style="{StaticResource TextFieldStyle}"
                                                     AutomationProperties.Name="邮箱" />
                                            <TextBlock Grid.Row="4"
                                                       Grid.ColumnSpan="2"
                                                       Text="密码"
                                                       Style="{StaticResource FormLabelStyle}"
                                                       Margin="0,16,0,6" />
                                            <PasswordBox x:Name="RegisterPasswordBox"
                                                         Grid.Row="5"
                                                         Grid.ColumnSpan="2"
                                                         Style="{StaticResource PasswordFieldStyle}"
                                                         AutomationProperties.Name="注册密码" />
                                            <TextBlock Grid.Row="6"
                                                       Grid.ColumnSpan="2"
                                                       Text="至少 10 位，并同时包含字母与数字。"
                                                       FontSize="11"
                                                       Foreground="{StaticResource InkFaintBrush}"
                                                       Margin="0,6,0,0" />
                                            <Button Grid.Row="7"
                                                    Grid.ColumnSpan="2"
                                                    Height="46"
                                                    Margin="0,18,0,0"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="RegisterAccountButton_OnClick">
                                                <TextBlock Text="创建赫朝账号"
                                                           Foreground="White"
                                                           FontSize="14"
                                                           FontWeight="Bold" />
                                            </Button>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                                <TextBlock Text="{Binding AccountFormMessage}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           TextTrimming="None"
                                           Margin="0,14,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SteelBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAccountFormError}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource HechaoRedDarkBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,26,0,0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="37*" />
                                <ColumnDefinition Width="63*" />
                            </Grid.ColumnDefinitions>

                            <Border Margin="0,0,12,0"
                                    Style="{StaticResource SurfacePanelStyle}"
                                    Padding="26">
                                <StackPanel>
                                    <Border Width="66"
                                            Height="66"
                                            HorizontalAlignment="Left"
                                            Background="{StaticResource HechaoRedSoftBrush}"
                                            BorderBrush="#FFD8B2AD"
                                            BorderThickness="1"
                                            CornerRadius="5">
                                        <controls:IconParkIcon Kind="User"
                                                               Width="28"
                                                               Height="28"
                                                               Foreground="{StaticResource HechaoRedDarkBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding AccountDisplayName}"
                                               FontSize="24"
                                               FontWeight="Black"
                                               Margin="0,18,0,0" />
                                    <TextBlock Text="{Binding AccountUsername}"
                                               FontFamily="Segoe UI"
                                               FontSize="13"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,4,0,0" />
                                    <Border Height="1"
                                            Background="{StaticResource BorderBrush}"
                                            Margin="0,22,0,18" />
                                    <TextBlock Text="账户状态"
                                               FontSize="11"
                                               Foreground="{StaticResource InkFaintBrush}" />
                                    <TextBlock Text="{Binding AccountStatusText}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Margin="0,5,0,0" />
                                    <TextBlock Text="{Binding AccountAccessText}"
                                               FontSize="12"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Margin="0,6,0,0" />
                                    <Button Margin="0,24,0,0"
                                            Style="{StaticResource BaseButtonStyle}"
                                            Command="{Binding LogoutAccountCommand}"
                                            Content="退出赫朝账号" />
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <Border Style="{StaticResource SurfacePanelStyle}"
                                        Padding="24">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40"
                                                Height="40"
                                                Background="{StaticResource SteelSoftBrush}"
                                                CornerRadius="4"
                                                VerticalAlignment="Top">
                                            <controls:IconParkIcon Kind="Shield"
                                                                   Width="18"
                                                                   Height="18"
                                                                   Foreground="{StaticResource SteelBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,20,0">
                                            <TextBlock Text="Minecraft Java 正版身份"
                                                       FontSize="16"
                                                       FontWeight="Black" />
                                            <TextBlock Text="{Binding MinecraftLinkStatusText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None"
                                                       Margin="0,6,0,0" />
                                            <TextBlock Text="{Binding MinecraftIdentityText}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Margin="0,9,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                MinWidth="176"
                                                Height="46"
                                                Command="{Binding LinkMinecraftCommand}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="绑定 Microsoft 正版身份"
                                                       Foreground="White"
                                                       FontSize="14"
                                                       FontWeight="Bold" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource SurfacePanelStyle}"
                                        Padding="24"
                                        Margin="0,16,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40"
                                                Height="40"
                                                Background="{StaticResource HechaoRedSoftBrush}"
                                                CornerRadius="4">
                                            <controls:IconParkIcon Kind="Lock"
                                                                   Width="18"
                                                                   Height="18"
                                                                   Foreground="{StaticResource HechaoRedDarkBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0,20,0">
                                            <TextBlock Text="LuckPerms 权限"
                                                       FontSize="16"
                                                       FontWeight="Black" />
                                            <TextBlock Text="{Binding AccountAccessText}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Command="{Binding OpenAdminConsoleCommand}"
                                                Content="{Binding AdminConsoleButtonText}"
                                                VerticalAlignment="Center"
                                                MinWidth="132">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAdministrator}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>

                                <Border Margin="0,16,0,0"
                                        Padding="18"
                                        Background="{StaticResource StripBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <TextBlock Text="{Binding AccountFormMessage}"
                                               FontSize="12"
                                               Foreground="{StaticResource HechaoRedDarkBrush}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Settings page -->
            <Grid Grid.Column="1"
                  Grid.ColumnSpan="2"
                  Grid.Row="1"
                  Background="{StaticResource CanvasBrush}"
                  Visibility="{Binding IsSettingsPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="34,28,34,34" MaxWidth="1180">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="LAUNCHER CONFIGURATION"
                                       Style="{StaticResource PageEyebrowStyle}" />
                            <TextBlock Text="设置"
                                       Style="{StaticResource PageHeaderTitleStyle}"
                                       Margin="0,5,0,0" />
                            <TextBlock Text="所有选项会立即保存，并在对应的下一次安装或启动时生效。"
                                       FontSize="13"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       Margin="0,7,0,0" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,24,0,0"
                                Style="{StaticResource SurfacePanelStyle}"
                                Padding="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="游戏与运行"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="适用于所有由赫朝启动器管理的客户端档案。"
                                               FontSize="12"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Margin="0,7,28,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="游戏内存"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <ListBox Style="{StaticResource MemorySegmentListStyle}"
                                             ItemContainerStyle="{StaticResource MemorySegmentItemStyle}"
                                             ItemsSource="{Binding MemoryOptions}"
                                             SelectedItem="{Binding SelectedMemory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Grid Margin="0,22,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="游戏启动后关闭启动器"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="Minecraft 进程成功创建后自动退出启动器。"
                                                       FontSize="11"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Style="{StaticResource SwitchToggleStyle}"
                                                      IsChecked="{Binding CloseLauncherAfterGameStart, Mode=TwoWay}"
                                                      VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Margin="0,16,0,0"
                                Style="{StaticResource SurfacePanelStyle}"
                                Padding="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="客户端与下载"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="目录变更不会移动已有文件，新的安装会写入新位置。"
                                               FontSize="12"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Margin="0,7,28,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="客户端目录"
                                               Style="{StaticResource FormLabelStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Height="42"
                                                Background="{StaticResource SurfaceMutedBrush}"
                                                BorderBrush="{StaticResource BorderStrongBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <TextBlock Text="{Binding ClientDirectory}"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0" />
                                        </Border>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource BaseButtonStyle}"
                                                Margin="10,0,0,0"
                                                Click="ChooseClientDirectoryButton_OnClick"
                                                Content="更改目录" />
                                    </Grid>

                                    <Grid Margin="0,22,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="启动时检查客户端更新"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="进入服务器前比较客户端档案与最新发布清单。"
                                                       FontSize="11"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Style="{StaticResource SwitchToggleStyle}"
                                                      IsChecked="{Binding CheckForUpdates, Mode=TwoWay}"
                                                      VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,20,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="保留下载缓存"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="修复或断点续传时复用已经校验通过的对象。"
                                                       FontSize="11"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Style="{StaticResource SwitchToggleStyle}"
                                                      IsChecked="{Binding KeepDownloadsAfterClose, Mode=TwoWay}"
                                                      VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid Margin="0,20,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="安装时打开下载中心"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="开始安装或修复后自动切换到实时下载页面。"
                                                       FontSize="11"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      Style="{StaticResource SwitchToggleStyle}"
                                                      IsChecked="{Binding OpenDownloadsWhenInstalling, Mode=TwoWay}"
                                                      VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="0,16,0,0"
                                Style="{StaticResource SurfacePanelStyle}"
                                Padding="24">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="启动器行为"
                                               Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="设置首次打开的工作区，并管理本机启动器数据。"
                                               FontSize="12"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Margin="0,7,28,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="220" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="默认打开页面"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="下次启动赫朝启动器时首先显示的页面。"
                                                       FontSize="11"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="1"
                                                  Style="{StaticResource MemoryComboBoxStyle}"
                                                  ItemsSource="{Binding StartupPageOptions}"
                                                  SelectedItem="{Binding SelectedStartupPage, Mode=TwoWay}" />
                                    </Grid>
                                    <Border Height="1"
                                            Background="{StaticResource BorderBrush}"
                                            Margin="0,22,0,18" />
                                    <WrapPanel>
                                        <Button Style="{StaticResource BaseButtonStyle}"
                                                Command="{Binding OpenClientDirectoryCommand}"
                                                Margin="0,0,8,8"
                                                Content="打开客户端目录" />
                                        <Button Style="{StaticResource BaseButtonStyle}"
                                                Command="{Binding ClearDownloadHistoryCommand}"
                                                Margin="0,0,8,8"
                                                Content="清空下载历史" />
                                        <Button Style="{StaticResource BaseButtonStyle}"
                                                Command="{Binding ResetLauncherSettingsCommand}"
                                                Margin="0,0,8,8"
                                                Content="恢复默认设置" />
                                    </WrapPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Notification center -->
            <Border Grid.Column="2"
                    Grid.RowSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="360"
                    Margin="0,72,12,0"
                    Padding="18"
                    Panel.ZIndex="20"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Visibility="{Binding IsNotificationsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect Color="#36000000"
                                      BlurRadius="20"
                                      ShadowDepth="6"
                                      Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="通知中心" FontSize="17" FontWeight="Black" />
                            <TextBlock Text="服务器与客户端动态"
                                       FontSize="12"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource QuietIconButtonStyle}"
                                Width="34"
                                Height="34"
                                Content="&#xE711;"
                                Command="{Binding CloseOverlaysCommand}"
                                ToolTip="关闭" />
                    </Grid>

                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Margin="0,15,0,0"
                            Padding="0,15,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="30"
                                    Height="30"
                                    Background="{StaticResource HechaoRedSoftBrush}"
                                    CornerRadius="4"
                                    VerticalAlignment="Top">
                                <controls:IconParkIcon Kind="VolumeNotice"
                                                       Width="13"
                                                       Height="13"
                                                       Foreground="{StaticResource HechaoRedDarkBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="活动服开放安排"
                                           FontSize="14"
                                           FontWeight="Bold" />
                                <TextBlock Text="活动服务器会按录制计划开放，开放状态以服务器目录为准。"
                                           FontSize="12"
                                           LineHeight="16"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           Margin="0,5,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="30"
                                    Height="30"
                                    Background="{StaticResource SteelSoftBrush}"
                                    CornerRadius="4"
                                    VerticalAlignment="Top">
                                <controls:IconParkIcon Kind="CheckOne"
                                                       Width="13"
                                                       Height="13"
                                                       Foreground="{StaticResource SteelBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding SelectedProfileDisplayName}"
                                           FontSize="14"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding SelectedProfileMetaText}"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Settings drawer -->
            <Border Grid.Column="2"
                    Grid.RowSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="420"
                    Panel.ZIndex="22"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect Color="#30000000"
                                      BlurRadius="22"
                                      ShadowDepth="8"
                                      Direction="180" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="76" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="78" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="24,0,14,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="启动器设置"
                                       FontSize="19"
                                       FontWeight="Black" />
                            <TextBlock Text="客户端、性能与启动行为"
                                       FontSize="12"
                                       Foreground="{StaticResource InkMutedBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Style="{StaticResource QuietIconButtonStyle}"
                                Width="36"
                                Height="36"
                                Content="&#xE711;"
                                Command="{Binding CloseOverlaysCommand}"
                                ToolTip="关闭" />
                        <Border Height="1"
                                Background="{StaticResource BorderBrush}"
                                VerticalAlignment="Bottom" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24,20">
                            <TextBlock Text="性能"
                                       Style="{StaticResource SettingsSectionLabelStyle}" />
                            <Grid Height="56" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="126" />
                                </Grid.ColumnDefinitions>
                                <Border Width="34"
                                        Height="34"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource HechaoRedSoftBrush}"
                                        CornerRadius="4">
                                    <TextBlock Text="RAM"
                                               FontFamily="Consolas"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HechaoRedDarkBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="游戏内存" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="下次启动游戏时生效"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <ComboBox Grid.Column="2"
                                          Style="{StaticResource MemoryComboBoxStyle}"
                                          ItemsSource="{Binding MemoryOptions}"
                                          SelectedItem="{Binding SelectedMemory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,16" />

                            <TextBlock Text="存储"
                                       Style="{StaticResource SettingsSectionLabelStyle}" />
                            <Grid MinHeight="62" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="38" />
                                </Grid.ColumnDefinitions>
                                <Border Width="34"
                                        Height="34"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="{StaticResource SurfacePressedBrush}"
                                        CornerRadius="4">
                                    <controls:IconParkIcon Kind="Folder"
                                                           Width="14"
                                                           Height="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="0,2,8,0">
                                    <TextBlock Text="客户端目录" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ClientDirectory}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               LineHeight="14"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,5,0,0"
                                               TextWrapping="Wrap"
                                               TextTrimming="None" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Style="{StaticResource QuietIconButtonStyle}"
                                        Width="36"
                                        Height="36"
                                        Content="&#xE838;"
                                        Command="{Binding OpenClientDirectoryCommand}"
                                        ToolTip="打开客户端目录"
                                        VerticalAlignment="Top" />
                            </Grid>

                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,16" />

                            <TextBlock Text="启动行为"
                                       Style="{StaticResource SettingsSectionLabelStyle}" />
                            <Grid Height="50" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="34"
                                        Height="34"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource SurfacePressedBrush}"
                                        CornerRadius="4">
                                    <controls:IconParkIcon Kind="CheckOne"
                                                           Width="14"
                                                           Height="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="启动时检查更新" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="保持客户端与服务器版本一致"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <ToggleButton Grid.Column="2"
                                              Style="{StaticResource SwitchToggleStyle}"
                                              IsChecked="{Binding CheckForUpdates, Mode=TwoWay}"
                                              VerticalAlignment="Center" />
                            </Grid>
                            <Grid Height="50" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="34"
                                        Height="34"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource SurfacePressedBrush}"
                                        CornerRadius="4">
                                    <controls:IconParkIcon Kind="Download"
                                                           Width="14"
                                                           Height="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="关闭后保留下载任务" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="下次打开后可以继续下载"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <ToggleButton Grid.Column="2"
                                              Style="{StaticResource SwitchToggleStyle}"
                                              IsChecked="{Binding KeepDownloadsAfterClose, Mode=TwoWay}"
                                              VerticalAlignment="Center" />
                            </Grid>

                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,16" />

                            <TextBlock Text="账号与权限"
                                       Style="{StaticResource SettingsSectionLabelStyle}" />
                            <Grid Height="60" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="34"
                                        Height="34"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource SurfacePressedBrush}"
                                        CornerRadius="4">
                                    <controls:IconParkIcon Kind="User"
                                                           Width="14"
                                                           Height="14"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AccountDisplayName}"
                                               FontFamily="Segoe UI"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AccountAccessText}"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Style="{StaticResource BaseButtonStyle}"
                                        Height="36"
                                        Command="{Binding AccountActionCommand}"
                                        ToolTip="{Binding AccountActionTooltip}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:IconParkIcon Glyph="{Binding AccountActionGlyph}"
                                                               Width="13"
                                                               Height="13"
                                                               Margin="0,0,7,0" />
                                        <TextBlock Text="{Binding AccountActionTooltip}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Button Style="{StaticResource BaseButtonStyle}"
                                    Height="38"
                                    Margin="42,8,0,0"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding OpenAdminConsoleCommand}"
                                    Visibility="{Binding IsAdministrator, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    ToolTip="在浏览器中打开安全管理后台">
                                <StackPanel Orientation="Horizontal">
                                    <controls:IconParkIcon Kind="ExternalTransmission"
                                                           Width="13"
                                                           Height="13"
                                                           Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding AdminConsoleButtonText}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Background="{StaticResource StripBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid Margin="24,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding LauncherVersionText, StringFormat=赫朝启动器 {0}}"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="非 Minecraft 官方产品，与 Mojang 或 Microsoft 无关联。"
                                           FontSize="10"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource OnlineBrush}" Margin="0,0,6,0" />
                                <TextBlock Text="设置自动保存"
                                           FontSize="11"
                                           Foreground="{StaticResource InkMutedBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Toast -->
            <Border Grid.Column="2"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,14"
                    Padding="17,10"
                    Panel.ZIndex="30"
                    Background="#F01B1A18"
                    CornerRadius="5"
                    Visibility="{Binding IsToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <controls:IconParkIcon Kind="CheckOne"
                                           Width="12"
                                           Height="12"
                                           Foreground="#FFFF5A51"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ToastMessage}"
                               Foreground="White"
                               FontSize="13"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
