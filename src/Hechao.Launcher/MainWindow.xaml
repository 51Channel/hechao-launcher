<Window x:Class="Hechao.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:contracts="clr-namespace:Hechao.Contracts;assembly=Hechao.Contracts"
        mc:Ignorable="d"
        Title="赫朝启动器"
        Width="1440"
        Height="900"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        FontFamily="{StaticResource UiFont}"
        Icon="/Assets/hechao-launcher.ico"
        Background="{StaticResource CanvasBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource CanvasBrush}"
            BorderBrush="#FFC9C8C4"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Background="{StaticResource SurfaceBrush}"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="276" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0,0,0">
                    <Border Width="38"
                            Height="38"
                            Background="{StaticResource HechaoRedBrush}"
                            CornerRadius="5">
                        <Image Source="/Assets/hechao-launcher-icon.png"
                               Width="32"
                               Height="32"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="赫朝" FontSize="19" FontWeight="Black" />
                        <TextBlock Text="HECHAO"
                                   FontFamily="Segoe UI"
                                   FontSize="8"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource InkMutedBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0">
                    <TextBlock Text="服务器"
                               FontSize="12"
                               Foreground="{StaticResource InkMutedBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="&#xE76C;"
                               FontFamily="{StaticResource IconFont}"
                               FontSize="10"
                               Foreground="{StaticResource InkFaintBrush}"
                               Margin="10,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SelectedServer.Name}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Grid Width="46" Height="64">
                        <Button Style="{StaticResource QuietIconButtonStyle}"
                                Width="38"
                                Height="38"
                                Content="&#xE7F4;"
                                Command="{Binding ToggleNotificationsCommand}"
                                ToolTip="通知"
                                AutomationProperties.Name="通知"
                                VerticalAlignment="Center" />
                        <Ellipse Width="6"
                                 Height="6"
                                 Fill="{StaticResource HechaoRedBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,17,7,0"
                                 IsHitTestVisible="False" />
                    </Grid>
                    <Button Style="{StaticResource QuietIconButtonStyle}"
                            Width="46"
                            Height="64"
                            Content="&#xE713;"
                            Command="{Binding ToggleSettingsCommand}"
                            ToolTip="启动器设置"
                            AutomationProperties.Name="启动器设置" />
                    <Border Width="1"
                            Height="24"
                            Background="{StaticResource BorderBrush}"
                            Margin="4,0,6,0"
                            VerticalAlignment="Center" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Height="64"
                            Content="&#xE921;"
                            Click="MinimizeButton_OnClick"
                            ToolTip="最小化" />
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Height="64"
                            Content="&#xE922;"
                            Click="MaximizeButton_OnClick"
                            ToolTip="最大化或还原" />
                    <Button Style="{StaticResource CloseButtonStyle}"
                            Height="64"
                            Content="&#xE8BB;"
                            Click="CloseButton_OnClick"
                            ToolTip="关闭" />
                </StackPanel>

                <Border Grid.ColumnSpan="3"
                        Height="1"
                        Background="{StaticResource BorderBrush}"
                        VerticalAlignment="Bottom" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="276" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="88" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="128" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="20,0,16,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="服务器大厅" FontSize="19" FontWeight="Black" />
                                <TextBlock Text="{Binding Servers.Count, StringFormat={}{0} 个可选世界}"
                                           FontSize="11"
                                           Foreground="{StaticResource InkMutedBrush}"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource IconButtonStyle}"
                                    Width="38"
                                    Height="38"
                                    FontSize="15"
                                    Content="&#xE72C;"
                                    Command="{Binding RefreshCommand}"
                                    ToolTip="刷新服务器状态"
                                    AutomationProperties.Name="刷新服务器状态" />
                        </Grid>

                        <ListBox Grid.Row="1"
                                 Margin="12,0,12,10"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemsSource="{Binding Servers}"
                                 SelectedItem="{Binding SelectedServer, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource ServerListItemStyle}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type contracts:ServerSummary}">
                                    <Grid Height="76">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5" />
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="54" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="4"
                                                Background="{StaticResource HechaoRedBrush}"
                                                CornerRadius="0,3,3,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                     Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Width="42"
                                                Height="42"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                            <TextBlock Text="{Binding ShortName}"
                                                       FontSize="17"
                                                       FontWeight="Black"
                                                       Foreground="{StaticResource HechaoRedDarkBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    Margin="3,0,4,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="Bold" />
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Ellipse Width="7"
                                                         Height="7"
                                                         Margin="0,0,6,0"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource ClosedBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}"
                                                                             Value="{x:Static contracts:ServerStatus.Online}">
                                                                    <Setter Property="Fill" Value="{StaticResource OnlineBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}"
                                                                             Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                                    <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock FontSize="10" Foreground="{StaticResource InkMutedBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="未开放" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}"
                                                                             Value="{x:Static contracts:ServerStatus.Online}">
                                                                    <Setter Property="Text" Value="在线" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}"
                                                                             Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                                    <Setter Property="Text" Value="维护中" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,0,10,0">
                                            <TextBlock Text="{Binding OnlinePlayers}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock FontFamily="Segoe UI"
                                                       FontSize="9"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       HorizontalAlignment="Right">
                                                <Run Text="/" />
                                                <Run Text="{Binding MaxPlayers}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2"
                                Margin="16,0"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid Margin="0,16,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="44"
                                        Height="44"
                                        Background="#FFD3A171"
                                        BorderBrush="#FFB87D4E"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        VerticalAlignment="Center">
                                    <Canvas Width="38" Height="38" ClipToBounds="True">
                                        <Rectangle Canvas.Left="4" Canvas.Top="3" Width="30" Height="26" Fill="#FFB56E3E" />
                                        <Rectangle Canvas.Left="4" Canvas.Top="3" Width="30" Height="9" Fill="#FF3B2419" />
                                        <Rectangle Canvas.Left="4" Canvas.Top="10" Width="6" Height="10" Fill="#FF3B2419" />
                                        <Rectangle Canvas.Left="28" Canvas.Top="10" Width="6" Height="10" Fill="#FF3B2419" />
                                        <Rectangle Canvas.Left="10" Canvas.Top="16" Width="6" Height="5" Fill="#FFF8F2EA" />
                                        <Rectangle Canvas.Left="23" Canvas.Top="16" Width="6" Height="5" Fill="#FFF8F2EA" />
                                        <Rectangle Canvas.Left="12" Canvas.Top="17" Width="3" Height="3" Fill="#FF2C1A15" />
                                        <Rectangle Canvas.Left="24" Canvas.Top="17" Width="3" Height="3" Fill="#FF2C1A15" />
                                        <Rectangle Canvas.Left="8" Canvas.Top="29" Width="22" Height="9" Fill="#FF263C2D" />
                                    </Canvas>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="5,0,5,0">
                                    <TextBlock Text="{Binding AccountDisplayName}"
                                               FontFamily="Segoe UI"
                                               FontSize="15"
                                               FontWeight="Bold" />
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource ClosedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource OnlineBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding AccountStatusText}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource InkMutedBrush}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding AccountAccessText}"
                                               FontSize="9"
                                               Foreground="{StaticResource InkFaintBrush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Style="{StaticResource QuietIconButtonStyle}"
                                        Width="36"
                                        Height="36"
                                        Content="{Binding AccountActionGlyph}"
                                        Command="{Binding AccountActionCommand}"
                                        ToolTip="{Binding AccountActionTooltip}"
                                        AutomationProperties.Name="{Binding AccountActionTooltip}"
                                        VerticalAlignment="Center" />

                                <Button Grid.Column="3"
                                        Style="{StaticResource QuietIconButtonStyle}"
                                        Width="36"
                                        Height="36"
                                        Content="&#xE713;"
                                        Command="{Binding ToggleSettingsCommand}"
                                        ToolTip="启动器设置"
                                        AutomationProperties.Name="启动器设置"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="300" />
                        <RowDefinition Height="50" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FF1A1917"
                            CornerRadius="6"
                            ClipToBounds="True">
                        <Grid>
                            <Image Source="/Assets/hechao-fortress-banner.png"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality" />

                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="20"
                                    Padding="11,7"
                                    Background="#EEFFFFFF"
                                    CornerRadius="4">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,7,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource ClosedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedServer.Status}"
                                                                 Value="{x:Static contracts:ServerStatus.Online}">
                                                        <Setter Property="Fill" Value="{StaticResource OnlineBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedServer.Status}"
                                                                 Value="{x:Static contracts:ServerStatus.Maintenance}">
                                                        <Setter Property="Fill" Value="{StaticResource WarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding SelectedServerStatusText}"
                                               FontSize="11"
                                               FontWeight="Bold" />
                                    <Border Width="1"
                                            Height="13"
                                            Background="{StaticResource BorderBrush}"
                                            Margin="10,0" />
                                    <TextBlock Text="{Binding SelectedServerCategoryText}"
                                               FontSize="11"
                                               Foreground="{StaticResource HechaoRedDarkBrush}"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border VerticalAlignment="Bottom"
                                    MinHeight="146"
                                    Background="#E9161513">
                                <Grid Margin="24,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedServer.Name}"
                                                   Foreground="White"
                                                   FontSize="34"
                                                   FontWeight="Black" />
                                        <TextBlock Text="{Binding SelectedServerDescriptionText}"
                                                   Foreground="#FFD3D0CB"
                                                   FontSize="12"
                                                   Margin="0,7,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <TextBlock Text="{Binding SelectedServerVersionText}"
                                                       Foreground="#FFF2F0EC"
                                                       FontFamily="Segoe UI"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                            <Border Width="1"
                                                    Height="12"
                                                    Background="#FF5E5A55"
                                                    Margin="11,0" />
                                            <TextBlock Text="{Binding SelectedServerAccessText}"
                                                       Foreground="#FFD3D0CB"
                                                       FontSize="11" />
                                            <Border Width="1"
                                                    Height="12"
                                                    Background="#FF5E5A55"
                                                    Margin="11,0" />
                                            <Ellipse Width="7"
                                                     Height="7"
                                                     Fill="{StaticResource OnlineBrush}"
                                                     Margin="0,0,6,0"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding SelectedServerPlayerText}"
                                                       Foreground="#FFD3D0CB"
                                                       FontFamily="Segoe UI"
                                                       FontSize="11" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Width="230"
                                            Height="58"
                                            Margin="26,0,0,0"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding PrimaryActionCommand}"
                                            AutomationProperties.Name="{Binding PrimaryActionText}"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE768;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="16"
                                                       Foreground="White"
                                                       Margin="0,0,10,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding PrimaryActionText}"
                                                       Foreground="White"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,8,0,0"
                            Background="#FF191816"
                            CornerRadius="5">
                        <Grid Margin="16,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE789;"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="15"
                                       Foreground="#FFFF5047"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="赫朝快讯"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Margin="0,0,16,0" />
                                <TextBlock Text="活动服务器会按录制计划开放，客户端将自动匹配当前版本。"
                                           Foreground="#FFCBC8C3"
                                           FontSize="11" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Style="{StaticResource QuietIconButtonStyle}"
                                    Width="36"
                                    Height="36"
                                    Foreground="#FFFF5047"
                                    Content="&#xE70D;"
                                    Command="{Binding ToggleNotificationsCommand}"
                                    ToolTip="查看通知" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="0,8,0,0"
                            Style="{StaticResource SurfacePanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="54" />
                                <RowDefinition Height="1" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="42" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="18,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="32"
                                        Height="32"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource HechaoRedSoftBrush}"
                                        CornerRadius="4">
                                    <TextBlock Text="&#xE7B8;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="14"
                                               Foreground="{StaticResource HechaoRedDarkBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="启动准备"
                                               FontSize="15"
                                               FontWeight="Black" />
                                    <TextBlock Text="·"
                                               Foreground="{StaticResource InkFaintBrush}"
                                               Margin="9,0" />
                                    <TextBlock Text="{Binding ClientStatusText}"
                                               FontSize="11"
                                               Foreground="{StaticResource InkMutedBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding LauncherVersionText, StringFormat=启动器 {0}}"
                                           FontFamily="Segoe UI"
                                           FontSize="10"
                                           Foreground="{StaticResource InkFaintBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Border Grid.Row="1" Background="{StaticResource BorderBrush}" />

                            <Grid Grid.Row="2" Margin="18,13">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="客户端档案"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}" />
                                    <TextBlock Text="{Binding SelectedProfileDisplayName}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Margin="0,5,0,0" />
                                    <TextBlock Text="{Binding SelectedProfileMetaText}"
                                               FontFamily="Segoe UI"
                                               FontSize="10"
                                               Foreground="{StaticResource InkFaintBrush}"
                                               Margin="0,4,0,0" />
                                </StackPanel>

                                <Grid Grid.Column="1" Margin="18,0,24,0" VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="客户端进度"
                                                   FontSize="10"
                                                   Foreground="{StaticResource InkMutedBrush}" />
                                        <TextBlock Text="{Binding UpdateProgress, StringFormat={}{0:0}%}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                    <ProgressBar Grid.Row="1"
                                                 Style="{StaticResource HechaoProgressBarStyle}"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding UpdateProgress, Mode=OneWay}"
                                                 Margin="0,9,0,0" />
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding ClientStatusText}"
                                               FontSize="10"
                                               Foreground="{StaticResource InkFaintBrush}"
                                               Margin="0,6,0,0" />
                                </Grid>

                                <StackPanel Grid.Column="2"
                                            Margin="0,0,18,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="游戏内存"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,0,0,6" />
                                    <ComboBox Style="{StaticResource MemoryComboBoxStyle}"
                                              ItemsSource="{Binding MemoryOptions}"
                                              SelectedItem="{Binding SelectedMemory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="3"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Style="{StaticResource BaseButtonStyle}"
                                            Height="40"
                                            Command="{Binding RepairCommand}"
                                            ToolTip="校验并修复当前客户端">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE90F;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="14"
                                                       Margin="0,0,8,0" />
                                            <TextBlock Text="修复客户端"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource IconButtonStyle}"
                                            Width="40"
                                            Height="40"
                                            Margin="8,0,0,0"
                                            Content="&#xE838;"
                                            Command="{Binding OpenClientDirectoryCommand}"
                                            ToolTip="打开客户端目录"
                                            AutomationProperties.Name="打开客户端目录" />
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="3"
                                    Background="{StaticResource SurfaceMutedBrush}"
                                    CornerRadius="0,0,6,6">
                                <Grid Margin="18,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE8B7;"
                                               FontFamily="{StaticResource IconFont}"
                                               FontSize="12"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ClientDirectory}"
                                               FontFamily="Consolas"
                                               FontSize="9"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="设置自动保存"
                                               FontSize="9"
                                               Foreground="{StaticResource InkFaintBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.RowSpan="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="360"
                            Margin="0,8,8,0"
                            Padding="18"
                            Panel.ZIndex="20"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{Binding IsNotificationsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect Color="#36000000"
                                              BlurRadius="20"
                                              ShadowDepth="6"
                                              Direction="270" />
                        </Border.Effect>
                        <StackPanel>
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="通知中心" FontSize="16" FontWeight="Black" />
                                    <TextBlock Text="服务器与客户端动态"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource QuietIconButtonStyle}"
                                        Width="34"
                                        Height="34"
                                        Content="&#xE711;"
                                        Command="{Binding CloseOverlaysCommand}"
                                        ToolTip="关闭" />
                            </Grid>

                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Margin="0,15,0,0"
                                    Padding="0,15,0,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30"
                                            Height="30"
                                            Background="{StaticResource HechaoRedSoftBrush}"
                                            CornerRadius="4"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="&#xE789;"
                                                   FontFamily="{StaticResource IconFont}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource HechaoRedDarkBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="活动服开放安排"
                                                   FontSize="12"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="活动服务器会按录制计划开放，开放状态以左侧列表为准。"
                                                   FontSize="10"
                                                   LineHeight="16"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   Margin="0,5,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,14,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="30"
                                            Height="30"
                                            Background="{StaticResource SurfacePressedBrush}"
                                            CornerRadius="4"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="&#xE895;"
                                                   FontFamily="{StaticResource IconFont}"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding SelectedProfileDisplayName}"
                                                   FontSize="12"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding SelectedProfileMetaText}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="10"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   Margin="0,5,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.RowSpan="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Stretch"
                            Width="410"
                            Margin="0"
                            Panel.ZIndex="22"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1,0,0,0"
                            Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect Color="#30000000"
                                              BlurRadius="22"
                                              ShadowDepth="8"
                                              Direction="180" />
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="74" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="76" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="22,0,14,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="启动器设置"
                                               FontSize="19"
                                               FontWeight="Black" />
                                    <TextBlock Text="客户端、性能与启动行为"
                                               FontSize="10"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource QuietIconButtonStyle}"
                                        Width="36"
                                        Height="36"
                                        Content="&#xE711;"
                                        Command="{Binding CloseOverlaysCommand}"
                                        ToolTip="关闭" />
                                <Border Height="1"
                                        Background="{StaticResource BorderBrush}"
                                        VerticalAlignment="Bottom" />
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="22,20">
                                    <TextBlock Text="性能"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HechaoRedDarkBrush}" />
                                    <Grid Height="54" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="126" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource HechaoRedSoftBrush}"
                                                CornerRadius="4">
                                            <TextBlock Text="RAM"
                                                       FontFamily="Consolas"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource HechaoRedDarkBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="游戏内存"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="下次启动游戏时生效"
                                                       FontSize="9"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                        <ComboBox Grid.Column="2"
                                                  Style="{StaticResource MemoryComboBoxStyle}"
                                                  ItemsSource="{Binding MemoryOptions}"
                                                  SelectedItem="{Binding SelectedMemory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Border Height="1"
                                            Background="{StaticResource BorderBrush}"
                                            Margin="0,16" />

                                    <TextBlock Text="存储"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HechaoRedDarkBrush}" />
                                    <Grid MinHeight="62" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="38" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Background="{StaticResource SurfacePressedBrush}"
                                                CornerRadius="4">
                                            <TextBlock Text="&#xE8B7;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="0,2,8,0">
                                            <TextBlock Text="客户端目录"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding ClientDirectory}"
                                                       FontFamily="Consolas"
                                                       FontSize="9"
                                                       LineHeight="14"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,5,0,0"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="None" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource QuietIconButtonStyle}"
                                                Width="36"
                                                Height="36"
                                                Content="&#xE838;"
                                                Command="{Binding OpenClientDirectoryCommand}"
                                                ToolTip="打开客户端目录"
                                                VerticalAlignment="Top" />
                                    </Grid>

                                    <Border Height="1"
                                            Background="{StaticResource BorderBrush}"
                                            Margin="0,16" />

                                    <TextBlock Text="启动行为"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HechaoRedDarkBrush}" />
                                    <Grid Height="48" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource SurfacePressedBrush}"
                                                CornerRadius="4">
                                            <TextBlock Text="&#xE895;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="启动时检查更新"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="保持客户端与服务器版本一致"
                                                       FontSize="9"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="2"
                                                      Style="{StaticResource SwitchToggleStyle}"
                                                      IsChecked="{Binding CheckForUpdates, Mode=TwoWay}"
                                                      VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid Height="48" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource SurfacePressedBrush}"
                                                CornerRadius="4">
                                            <TextBlock Text="&#xE896;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="关闭后保留下载任务"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="下次打开后可以继续下载"
                                                       FontSize="9"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                        <ToggleButton Grid.Column="2"
                                                      Style="{StaticResource SwitchToggleStyle}"
                                                      IsChecked="{Binding KeepDownloadsAfterClose, Mode=TwoWay}"
                                                      VerticalAlignment="Center" />
                                    </Grid>

                                    <Border Height="1"
                                            Background="{StaticResource BorderBrush}"
                                            Margin="0,16" />

                                    <TextBlock Text="账号与权限"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource HechaoRedDarkBrush}" />
                                    <Grid Height="58" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34"
                                                Height="34"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource SurfacePressedBrush}"
                                                CornerRadius="4">
                                            <TextBlock Text="&#xE77B;"
                                                       FontFamily="{StaticResource IconFont}"
                                                       FontSize="14"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AccountDisplayName}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding AccountAccessText}"
                                                       FontSize="9"
                                                       Foreground="{StaticResource InkMutedBrush}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource BaseButtonStyle}"
                                                Height="36"
                                                Command="{Binding AccountActionCommand}"
                                                ToolTip="{Binding AccountActionTooltip}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding AccountActionGlyph}"
                                                           FontFamily="{StaticResource IconFont}"
                                                           FontSize="13"
                                                           Margin="0,0,7,0" />
                                                <TextBlock Text="{Binding AccountActionTooltip}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="2"
                                    Background="{StaticResource SurfaceMutedBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <Grid Margin="22,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding LauncherVersionText, StringFormat=赫朝启动器 {0}}"
                                                   FontFamily="Segoe UI"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="非 Minecraft 官方产品，与 Mojang 或 Microsoft 无关联。"
                                                   FontSize="8"
                                                   Foreground="{StaticResource InkMutedBrush}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <StackPanel HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Ellipse Width="7"
                                                 Height="7"
                                                 Fill="{StaticResource OnlineBrush}"
                                                 Margin="0,0,6,0" />
                                        <TextBlock Text="设置自动保存"
                                                   FontSize="9"
                                                   Foreground="{StaticResource InkMutedBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,14"
                            Padding="17,10"
                            Panel.ZIndex="30"
                            Background="#F01B1A18"
                            CornerRadius="5"
                            Visibility="{Binding IsToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;"
                                       FontFamily="{StaticResource IconFont}"
                                       FontSize="12"
                                       Foreground="#FFFF5A51"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ToastMessage}"
                                       Foreground="White"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
