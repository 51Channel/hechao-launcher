<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Hechao.Launcher.Controls">
    <Color x:Key="CanvasColor">#FFF1F2F0</Color>
    <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="SurfaceMutedColor">#FFF7F7F5</Color>
    <Color x:Key="SurfacePressedColor">#FFECEDE9</Color>
    <Color x:Key="RailColor">#FFFDFDFC</Color>
    <Color x:Key="DirectoryColor">#FFF8F8F6</Color>
    <Color x:Key="StripColor">#FFFAFAF8</Color>
    <Color x:Key="InkColor">#FF171716</Color>
    <Color x:Key="InkMutedColor">#FF666762</Color>
    <Color x:Key="InkFaintColor">#FF969892</Color>
    <Color x:Key="HechaoRedColor">#FFB3261E</Color>
    <Color x:Key="HechaoRedDarkColor">#FF861A14</Color>
    <Color x:Key="HechaoRedSoftColor">#FFF9E9E7</Color>
    <Color x:Key="BorderColor">#FFE1E2DE</Color>
    <Color x:Key="BorderStrongColor">#FFBFC2BC</Color>
    <Color x:Key="SteelColor">#FF62737D</Color>
    <Color x:Key="SteelSoftColor">#FFEDF1F2</Color>
    <Color x:Key="OnlineColor">#FF34865A</Color>
    <Color x:Key="WarningColor">#FFD39128</Color>
    <Color x:Key="ClosedColor">#FF979A94</Color>

    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource SurfaceMutedColor}" />
    <SolidColorBrush x:Key="SurfacePressedBrush" Color="{StaticResource SurfacePressedColor}" />
    <SolidColorBrush x:Key="RailBrush" Color="{StaticResource RailColor}" />
    <SolidColorBrush x:Key="DirectoryBrush" Color="{StaticResource DirectoryColor}" />
    <SolidColorBrush x:Key="StripBrush" Color="{StaticResource StripColor}" />
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="InkMutedBrush" Color="{StaticResource InkMutedColor}" />
    <SolidColorBrush x:Key="InkFaintBrush" Color="{StaticResource InkFaintColor}" />
    <SolidColorBrush x:Key="HechaoRedBrush" Color="{StaticResource HechaoRedColor}" />
    <SolidColorBrush x:Key="HechaoRedDarkBrush" Color="{StaticResource HechaoRedDarkColor}" />
    <SolidColorBrush x:Key="HechaoRedSoftBrush" Color="{StaticResource HechaoRedSoftColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="SteelBrush" Color="{StaticResource SteelColor}" />
    <SolidColorBrush x:Key="SteelSoftBrush" Color="{StaticResource SteelSoftColor}" />
    <SolidColorBrush x:Key="OnlineBrush" Color="{StaticResource OnlineColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ClosedBrush" Color="{StaticResource ClosedColor}" />

    <FontFamily x:Key="UiFont">.PingFang SC, PingFang SC, Microsoft YaHei UI, Segoe UI</FontFamily>

    <DataTemplate x:Key="IconParkButtonContentTemplate">
        <controls:IconParkIcon Glyph="{Binding}"
                               Width="18"
                               Height="18"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
    </DataTemplate>

    <DataTemplate x:Key="IconParkTitleBarContentTemplate">
        <controls:IconParkIcon Glyph="{Binding}"
                               Width="14"
                               Height="14"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
    </DataTemplate>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed" />
    </Style>

    <Style x:Key="SurfacePanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource HechaoRedSoftBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFD5A8A2" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="#FFF2D8D5" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.42" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="54" />
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource HechaoRedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource HechaoRedDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PrimaryBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PrimaryBorder" Property="Background" Value="#FFBD3027" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="PrimaryBorder" Property="Background" Value="{StaticResource HechaoRedDarkBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PrimaryBorder" Property="Background" Value="#FFB6B4B0" />
                            <Setter TargetName="PrimaryBorder" Property="BorderBrush" Value="#FFA3A19D" />
                            <Setter TargetName="PrimaryBorder" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ContentTemplate" Value="{StaticResource IconParkButtonContentTemplate}" />
    </Style>

    <Style x:Key="QuietIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style x:Key="RailButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Width" Value="66" />
        <Setter Property="Height" Value="68" />
        <Setter Property="MinHeight" Value="68" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
    </Style>

    <Style x:Key="RailSelectedButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="66" />
        <Setter Property="Height" Value="68" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{StaticResource HechaoRedSoftBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource HechaoRedDarkBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="SelectedRailBackground"
                                Margin="4,0"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5" />
                        <Border Width="3"
                                HorizontalAlignment="Left"
                                Background="{StaticResource HechaoRedBrush}"
                                CornerRadius="0,2,2,0" />
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SelectedRailBackground" Property="Background" Value="#FFF5DCD9" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="SelectedRailBackground" Property="Opacity" Value="0.72" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ContentTemplate" Value="{StaticResource IconParkTitleBarContentTemplate}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ChromeBackground" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ChromeBackground" Property="Background" Value="{StaticResource SurfacePressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ChromeBackground" Property="Opacity" Value="0.68" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource HechaoRedBrush}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ServerListItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SurfaceBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource HechaoRedSoftBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#FFE3C8C4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HechaoProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="7" />
        <Setter Property="Background" Value="{StaticResource SurfacePressedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource HechaoRedBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid ClipToBounds="True">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" />
                        <Border x:Name="PART_Indicator"
                                HorizontalAlignment="Left"
                                Background="{TemplateBinding Foreground}"
                                CornerRadius="3" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProcessLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DetailRowStyle" TargetType="Grid">
        <Setter Property="Height" Value="40" />
    </Style>

    <Style x:Key="DetailRowIconStyle" TargetType="controls:IconParkIcon">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource SteelBrush}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DetailRowLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
        <Setter Property="Margin" Value="28,0,0,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="DetailRowValueStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SettingsSectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource HechaoRedDarkBrush}" />
    </Style>

    <Style x:Key="MemorySegmentListStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MemorySegmentItemStyle" TargetType="ListBoxItem">
        <Setter Property="Height" Value="38" />
        <Setter Property="Margin" Value="0,0,5,0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="MemorySegment"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MemorySegment" Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
                            <Setter TargetName="MemorySegment" Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="MemorySegment" Property="BorderBrush" Value="{StaticResource HechaoRedBrush}" />
                            <Setter TargetName="MemorySegment" Property="Background" Value="{StaticResource HechaoRedSoftBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource HechaoRedDarkBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MemoryComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="13,0,36,0" />
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="112" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Padding" Value="12,8" />
                    <Setter Property="Margin" Value="3,1" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="ItemBackground"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="4">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="ItemBackground" Property="Background" Value="{StaticResource SurfacePressedBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBackground" Property="Background" Value="{StaticResource HechaoRedSoftBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource HechaoRedDarkBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="ComboRoot" SnapsToDevicePixels="True">
                        <Border x:Name="FieldBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" />
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                        <controls:IconParkIcon x:Name="DropDownArrow"
                                               Kind="Down"
                                               Width="12"
                                               Height="12"
                                               Foreground="{StaticResource InkMutedBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0" />
                        <ToggleButton Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" />
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade"
                               IsOpen="{TemplateBinding IsDropDownOpen}">
                            <Border MinWidth="{TemplateBinding ActualWidth}"
                                    Margin="0,5,0,10"
                                    Padding="3"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <Border.Effect>
                                    <DropShadowEffect Color="#2B000000" BlurRadius="14" ShadowDepth="4" Direction="270" />
                                </Border.Effect>
                                <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="FieldBorder" Property="BorderBrush" Value="#FFBEBDB8" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource HechaoRedBrush}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="FieldBorder" Property="Background" Value="{StaticResource HechaoRedSoftBrush}" />
                            <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource HechaoRedBrush}" />
                            <Setter TargetName="DropDownArrow" Property="Kind" Value="Up" />
                            <Setter TargetName="DropDownArrow" Property="Foreground" Value="{StaticResource HechaoRedDarkBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ComboRoot" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SwitchToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="23" />
        <Setter Property="Background" Value="#FFD6D5D1" />
        <Setter Property="BorderBrush" Value="#FFC8C7C2" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="SwitchTrack"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" />
                        <Ellipse x:Name="SwitchThumb"
                                 Width="17"
                                 Height="17"
                                 Margin="3"
                                 HorizontalAlignment="Left"
                                 Fill="White">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#33000000" BlurRadius="3" ShadowDepth="1" Direction="270" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{StaticResource HechaoRedBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchTrack" Property="Background" Value="{StaticResource HechaoRedBrush}" />
                            <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{StaticResource HechaoRedDarkBrush}" />
                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RailNavigationToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="66" />
        <Setter Property="Height" Value="68" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="NavigationBackground"
                                Margin="4,0"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5" />
                        <Border x:Name="SelectionMarker"
                                Width="3"
                                HorizontalAlignment="Left"
                                Background="{StaticResource HechaoRedBrush}"
                                CornerRadius="0,2,2,0"
                                Visibility="Collapsed" />
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="NavigationBackground"
                                    Property="Background"
                                    Value="{StaticResource SurfacePressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource HechaoRedDarkBrush}" />
                            <Setter TargetName="NavigationBackground"
                                    Property="Background"
                                    Value="{StaticResource HechaoRedSoftBrush}" />
                            <Setter TargetName="SelectionMarker"
                                    Property="Visibility"
                                    Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="NavigationBackground" Property="Opacity" Value="0.72" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

